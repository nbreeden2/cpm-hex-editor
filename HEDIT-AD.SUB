; HEDIT-AD.SUB - build HEDIT-AD.COM (Lear Siegler ADM-31).
; Self-contained: rebuilds HEPATCH.COM first.
; ADM-31 is always mono; COLOR is normalised to 0.
M80 =HEPATCH
L80 HEPATCH,HEPATCH/N/E
HEPATCH 0
ERA *.REL
M80 =HEDIT
M80 =HEADM31
M80 =HEADM31K
M80 =HEXGAP
M80 =HEXIO
M80 =HEXMNVT
M80 =HEXSRCH
M80 =HEXBLK
M80 =HEXKBND
M80 =HEXVIRT
M80 =HEXHELP
L80 HEDIT,HEADM31,HEADM31K,HEXGAP,HEXIO,HEXMNVT,HEXSRCH,HEXBLK,HEXKBND,HEXVIRT,HEXHELP,TEMP/N/E
ERA HEDIT-AD.COM
REN HEDIT-AD.COM=TEMP.COM
