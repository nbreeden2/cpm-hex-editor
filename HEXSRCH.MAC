;============================================================
; FILE:    HEXSRCH.MAC
; PROJECT: HEDIT - Hex Editor for CP/M 2.2
; VERSION: 1.03
; DATE:    1984-01-01
; AUTHOR:  Claude Code and RetroTechReboot
;------------------------------------------------------------
; DESCRIPTION:
;   Search module for the hex editor. Supports searching
;   by hex byte patterns (space-separated pairs) or by
;   ASCII text strings. Searches forward from cursor with
;   wraparound.
;
;   SRFIND  - Prompt for search type and pattern, then find.
;   SRFNDNX - Find next occurrence of current pattern.
;------------------------------------------------------------
; REVISION HISTORY:
;   1.0  1984-01-01  Initial release
;============================================================

        INCLUDE HEDIT.INC

;--- Imports ----------------------------------------------
        EXTRN   CURBDP          ; current buffer descriptor
        EXTRN   DIRTY           ; screen redraw flag
        EXTRN   GBLOGRD         ; read byte at logical offset HL
        EXTRN   GBTXEND         ; get text end -> HL
        EXTRN   GBCSOFF         ; get cursor offset -> HL
        EXTRN   GBMVTO          ; move cursor to offset HL
        EXTRN   STATMSG         ; status bar message
        EXTRN   STATCLR         ; clear status bar
        EXTRN   OUTSTR          ; write $-string
        EXTRN   OUTCHAR         ; write single char
        EXTRN   CURGOTO         ; position cursor (B=row,C=col)
        EXTRN   RSTAT           ; runtime status row

;--- Exports ----------------------------------------------
        PUBLIC  SRFIND          ; find (prompt for pattern)
        PUBLIC  SRFNDNX         ; find next occurrence

;=============================================================
; SRFIND - Prompt for search type, then pattern, then search.
; Entry:  (none)
; Exit:   Cursor moved to match if found; all regs clobbered.
;=============================================================
        CSEG

SRFIND:
        ; Prompt for search type: Hex or ASCII
        LDA     RSTAT           ; B = runtime status row
        MOV     B,A
        MVI     C,1
        CALL    CURGOTO
        LXI     D,SRTYPMT
        CALL    OUTSTR

        ; Wait for H or A (or ESC to cancel)
SRTWT:  MVI     E,0FFH
        MVI     C,BF_RAWIO
        CALL    BDOS
        ORA     A
        JZ      SRTWT           ; no char, poll

        CPI     ESC
        JZ      SRCANC          ; cancelled

        CPI     'H'
        JZ      SRTHEX
        CPI     'h'
        JZ      SRTHEX
        CPI     'A'
        JZ      SRTASC
        CPI     'a'
        JZ      SRTASC
        JMP     SRTWT           ; invalid, try again

SRTHEX: MVI     A,0
        STA     SRCHTYP         ; type = hex
        ; Clear status line, then prompt for hex bytes
        CALL    STATCLR
        LDA     RSTAT           ; B = runtime status row
        MOV     B,A
        MVI     C,1
        CALL    CURGOTO
        LXI     D,SRHXPMT
        CALL    OUTSTR
        JMP     SRREAD

SRTASC: MVI     A,1
        STA     SRCHTYP         ; type = ASCII
        ; Clear status line, then prompt for ASCII text
        CALL    STATCLR
        LDA     RSTAT           ; B = runtime status row
        MOV     B,A
        MVI     C,1
        CALL    CURGOTO
        LXI     D,SRASPMT
        CALL    OUTSTR

SRREAD: ; Read input line (char-by-char, ESC cancels)
        XRA     A
        STA     SRINBUF+1       ; length = 0

SRRDLP: MVI     E,0FFH
        MVI     C,BF_RAWIO
        CALL    BDOS            ; clobbers all regs
        ORA     A
        JZ      SRRDLP          ; no char, poll

        CPI     ESC
        JZ      SRCANC          ; ESC cancels

        CPI     CR
        JZ      SRRDDN          ; Enter = done

        CPI     BS
        JZ      SRRDBK
        CPI     DEL
        JZ      SRRDBK

        ; Check buffer not full
        STA     SRRDCH          ; save char
        LDA     SRINBUF+1
        CPI     78
        JNC     SRRDLP          ; full, ignore

        ; Compute write pointer: SRINBUF+2 + length
        MOV     E,A
        MVI     D,0
        LXI     H,SRINBUF+2
        DAD     D               ; HL = write position

        ; Uppercase hex chars: convert a-f to A-F in hex mode
        LDA     SRCHTYP
        ORA     A
        JNZ     SRRDST          ; ASCII mode, no conversion
        LDA     SRRDCH
        CPI     'a'
        JC      SRRDST          ; < 'a', no change
        CPI     'z'+1
        JNC     SRRDST          ; > 'z', no change
        ANI     5FH             ; clear bit 5 -> uppercase
        STA     SRRDCH
SRRDST: ; Store character
        LDA     SRRDCH
        MOV     M,A

        ; Increment length
        LDA     SRINBUF+1
        INR     A
        STA     SRINBUF+1

        ; Echo the character
        LDA     SRRDCH
        CALL    OUTCHAR         ; clobbers all regs
        JMP     SRRDLP

SRRDBK: ; Backspace
        LDA     SRINBUF+1
        ORA     A
        JZ      SRRDLP          ; nothing to delete
        DCR     A
        STA     SRINBUF+1
        ; Erase char on screen: BS, space, BS
        MVI     A,BS
        CALL    OUTCHAR
        MVI     A,' '
        CALL    OUTCHAR
        MVI     A,BS
        CALL    OUTCHAR
        JMP     SRRDLP

SRRDDN: ; Enter pressed
        LDA     SRINBUF+1
        ORA     A
        JZ      SRCANC          ; empty = cancel

        ; Parse based on type
        LDA     SRCHTYP
        ORA     A
        JZ      SRDOHX          ; hex mode

        ; ASCII mode: copy input directly to SRCHBUF
        LDA     SRINBUF+1       ; length
        MOV     B,A             ; B = count
        STA     SRCHLEN
        LXI     H,SRINBUF+2     ; source
        LXI     D,SRCHBUF       ; dest
SRACPL: MOV     A,M
        STAX    D
        INX     H
        INX     D
        DCR     B
        JNZ     SRACPL
        JMP     SRFNDNX         ; now search

SRDOHX: ; Parse hex byte pairs from SRINBUF+2
        CALL    SRHXPAR
        LDA     SRCHLEN
        ORA     A
        JZ      SRCANC          ; no valid bytes parsed
        JMP     SRFNDNX         ; now search

SRCANC: ; Cancelled or empty
        CALL    STATCLR
        RET

;=============================================================
; SRFNDNX - Find next occurrence of SRCHBUF[0..SRCHLEN-1].
; Searches forward from CSOFF+1, wraps around if needed.
; Entry:  SRCHBUF and SRCHLEN must be valid.
; Exit:   Cursor moved to match if found; all regs clobbered.
;=============================================================
SRFNDNX:
        LDA     SRCHLEN
        ORA     A
        JZ      SRNOPAT         ; no pattern loaded

        ; Get cursor offset + 1 as start position
        CALL    GBCSOFF         ; HL = cursor offset
        INX     H
        SHLD    SRSTART         ; start of forward search

        ; Get text end
        CALL    GBTXEND         ; HL = TXEND
        SHLD    SRTXEND

        ; Reset wrap flag
        XRA     A
        STA     SRWRAP

        ; Begin forward search from SRSTART
        LHLD    SRSTART
        SHLD    SRPOS           ; current probe position

SRFLP:
        ; Check if SRPOS + SRCHLEN > SRTXEND
        LHLD    SRPOS
        LDA     SRCHLEN
        MOV     C,A
        MVI     B,0
        DAD     B               ; HL = SRPOS + SRCHLEN
        XCHG                    ; DE = SRPOS + SRCHLEN
        LHLD    SRTXEND         ; HL = SRTXEND
        ; Compare: if SRTXEND < SRPOS+len, go to wrap
        MOV     A,H
        CMP     D
        JC      SRFWRP          ; TXEND.H < (pos+len).H
        JNZ     SRFCHK          ; TXEND.H > (pos+len).H: ok
        MOV     A,L
        CMP     E
        JC      SRFWRP          ; TXEND < pos+len: past end

SRFCHK:
        ; Try to match at SRPOS
        LHLD    SRPOS
        CALL    SRTRY           ; Z set if match
        JZ      SRFND

        ; Advance SRPOS by 1
        LHLD    SRPOS
        INX     H
        SHLD    SRPOS
        JMP     SRFLP

SRFWRP:
        ; Check if we already wrapped
        LDA     SRWRAP
        ORA     A
        JNZ     SRNFND          ; second time around = not found

        ; Wrap: search from 0 to SRSTART
        MVI     A,1
        STA     SRWRAP
        LXI     H,0
        SHLD    SRPOS

SRWLP:
        ; Check SRPOS < SRSTART
        LHLD    SRPOS
        XCHG                    ; DE = SRPOS
        LHLD    SRSTART         ; HL = SRSTART
        ; if SRSTART <= SRPOS then stop
        MOV     A,H
        CMP     D
        JC      SRNFND          ; SRSTART.H < SRPOS.H: done
        JNZ     SRWCHK          ; SRSTART.H > SRPOS.H: continue
        MOV     A,L
        CMP     E
        JNC     SRNFND          ; SRSTART >= SRPOS: done

SRWCHK:
        ; Check SRPOS + SRCHLEN <= SRTXEND
        LHLD    SRPOS
        LDA     SRCHLEN
        MOV     C,A
        MVI     B,0
        DAD     B               ; HL = SRPOS + SRCHLEN
        XCHG                    ; DE = SRPOS + SRCHLEN
        LHLD    SRTXEND
        MOV     A,H
        CMP     D
        JC      SRNFND          ; past end
        JNZ     SRWOK
        MOV     A,L
        CMP     E
        JC      SRNFND

SRWOK:  LHLD    SRPOS
        CALL    SRTRY
        JZ      SRFND

        LHLD    SRPOS
        INX     H
        SHLD    SRPOS
        JMP     SRWLP

SRFND:
        ; Found at SRPOS: move cursor there
        XRA     A
        STA     SRWRAP          ; reset wrap flag
        LHLD    SRPOS
        CALL    GBMVTO          ; move cursor to match
        MVI     A,1
        STA     DIRTY

        ; Build "Found at offset XXXX" message
        ; Convert SRPOS to hex and display
        LHLD    SRPOS
        SHLD    SRFOFF          ; save for display
        LXI     D,SRFMSG
        JMP     STATMSG

SRNFND:
        XRA     A
        STA     SRWRAP
        LXI     D,SRNFMS
        JMP     STATMSG

SRNOPAT:
        ; No pattern - prompt via SRFIND instead
        JMP     SRFIND

;=============================================================
; SRTRY - Try to match SRCHBUF at logical offset HL.
; Entry:  HL = logical start offset to try
; Exit:   Zero flag set if full match, clear if no match.
;         Regs: all clobbered.
;=============================================================
SRTRY:
        SHLD    SRTPOS          ; save probe position
        LDA     SRCHLEN
        MOV     B,A             ; B = bytes remaining
        LXI     D,SRCHBUF       ; DE = pattern pointer
        LHLD    SRTPOS          ; HL = current offset

STRLP:
        MOV     A,B
        ORA     A
        JZ      STRMCH          ; all bytes matched

        ; Read logical byte at HL from gap buffer
        PUSH    B
        PUSH    D
        PUSH    H
        CALL    GBLOGRD         ; A = byte at logical HL
        STA     SRTBYT          ; save byte (GBLOGRD clobbers regs)
        POP     H
        POP     D
        POP     B

        ; Compare with pattern byte
        LDAX    D               ; A = pattern byte
        MOV     C,A             ; C = pattern byte
        LDA     SRTBYT          ; A = text byte
        CMP     C               ; compare
        RNZ                     ; no match (NZ flag set)

        INX     D               ; advance pattern
        INX     H               ; advance offset
        DCR     B
        JMP     STRLP

STRMCH: ; All bytes matched
        XRA     A               ; ensure Z set
        RET

;=============================================================
; SRHXPAR - Parse hex byte pairs from SRINBUF+2.
; Input string: space-separated hex pairs, e.g. "FF 00 A5"
; Exit:  SRCHBUF filled with raw bytes, SRCHLEN = count.
;        Regs: all clobbered.
;=============================================================
SRHXPAR:
        LDA     SRINBUF+1       ; input length
        ORA     A
        JZ      SHPDON
        MOV     B,A             ; B = chars remaining
        LXI     H,SRINBUF+2     ; HL = source pointer
        LXI     D,SRCHBUF       ; DE = dest pointer
        MVI     C,0             ; C = byte count
        XRA     A
        STA     SHPHI           ; high nibble flag (0=need high)
        STA     SHPACC          ; accumulator
        STA     SHPCNT          ; parsed byte count = 0

SHPLP:  MOV     A,B
        ORA     A
        JZ      SHPFIN          ; end of input

        MOV     A,M             ; read char
        INX     H               ; advance source
        DCR     B               ; decrement count

        ; Skip spaces
        CPI     ' '
        JZ      SHPSPC

        ; Convert hex char to nibble value
        CALL    SHPCHR          ; A = nibble (0-15), CY if invalid
        JC      SHPLP           ; invalid char, skip

        ; Accumulate nibble (A = nibble 0-15)
        STA     SHPNIB          ; save nibble value
        LDA     SHPHI
        ORA     A
        JNZ     SHPLO           ; already have high nibble

        ; High nibble: shift left 4
        LDA     SHPNIB
        RLC
        RLC
        RLC
        RLC
        ANI     0F0H
        STA     SHPACC
        MVI     A,1
        STA     SHPHI           ; flag: have high nibble
        JMP     SHPLP

SHPLO:  ; Low nibble: combine with high
        PUSH    H
        PUSH    B
        LDA     SHPNIB
        MOV     C,A             ; C = low nibble
        LDA     SHPACC
        ORA     C               ; combine
        STAX    D               ; store to SRCHBUF
        INX     D               ; advance dest
        POP     B
        POP     H
        ; Increment byte count (in memory to be safe)
        PUSH    PSW
        LDA     SHPCNT
        INR     A
        STA     SHPCNT
        POP     PSW
        ; Reset high nibble flag
        XRA     A
        STA     SHPHI
        STA     SHPACC
        JMP     SHPLP

SHPSPC: ; Space: if we have a pending high nibble, treat as
        ; a single-digit byte (e.g., "F " -> 0Fh)
        PUSH    H
        PUSH    B
        LDA     SHPHI
        ORA     A
        JZ      SHPSP2          ; no pending nibble
        ; Store high nibble as full byte (high already shifted)
        LDA     SHPACC
        ; Actually the high nibble is in upper 4 bits but
        ; for single digit "F " we want 0F, so shift right 4
        RRC
        RRC
        RRC
        RRC
        ANI     0FH
        STAX    D
        INX     D
        LDA     SHPCNT
        INR     A
        STA     SHPCNT
        XRA     A
        STA     SHPHI
        STA     SHPACC
SHPSP2: POP     B
        POP     H
        JMP     SHPLP

SHPFIN: ; End of input: check for pending nibble
        LDA     SHPHI
        ORA     A
        JZ      SHPDON
        ; Pending single nibble
        LDA     SHPACC
        RRC
        RRC
        RRC
        RRC
        ANI     0FH
        STAX    D
        LDA     SHPCNT
        INR     A
        STA     SHPCNT

SHPDON: LDA     SHPCNT
        STA     SRCHLEN
        RET

;------------------------------------------------------------
; SHPCHR - Convert hex ASCII char in A to nibble value.
; Entry:  A = character
; Exit:   A = nibble value (0-15), CY clear.
;         CY set if not a valid hex char.
;------------------------------------------------------------
SHPCHR:
        CPI     '0'
        JC      SHPINV          ; < '0'
        CPI     '9'+1
        JC      SHPD09          ; '0'-'9'
        CPI     'A'
        JC      SHPINV          ; ':'- '@'
        CPI     'F'+1
        JC      SHPDAF          ; 'A'-'F'
        CPI     'a'
        JC      SHPINV
        CPI     'f'+1
        JNC     SHPINV          ; > 'f'
        ; 'a'-'f'
        SUI     'a'-10
        ORA     A               ; clear carry
        RET
SHPD09: SUI     '0'
        ORA     A               ; clear carry
        RET
SHPDAF: SUI     'A'-10
        ORA     A               ; clear carry
        RET
SHPINV: STC                     ; set carry = invalid
        RET

;=============================================================
; DATA SEGMENT
;=============================================================
        DSEG

; Search pattern buffer (raw bytes)
SRCHBUF: DS     SRCHMAX         ; 64 bytes

; Search pattern length (byte count)
SRCHLEN: DB     0

; Search type (0=hex, 1=ASCII)
SRCHTYP: DB     0

; Input buffer for prompts
SRINBUF: DB     78              ; max length
         DB     0               ; actual length
         DS     80              ; input chars

; Search state
SRSTART: DW     0               ; start offset for this search
SRTXEND: DW     0               ; cached text end
SRPOS:   DW     0               ; current probe position
SRWRAP:  DB     0               ; 1 = wrapped around
SRTPOS:  DW     0               ; probe position for SRTRY
SRTBYT:  DB     0               ; byte read during SRTRY
SRFOFF:  DW     0               ; offset of last match (for display)

; Input char temp
SRRDCH:  DB     0               ; saved char during input

; Hex parser state
SHPNIB:  DB     0               ; current nibble value
SHPHI:   DB     0               ; high nibble flag
SHPACC:  DB     0               ; nibble accumulator
SHPCNT:  DB     0               ; byte count during parse

; Status messages
SRTYPMT: DB     'Search (H)ex or (A)SCII? $'
SRHXPMT: DB     'Hex bytes: $'
SRASPMT: DB     'ASCII text: $'
SRFMSG:  DB     'Found.$'
SRNFMS:  DB     'Not found.$'

        END
