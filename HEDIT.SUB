; HEDIT.SUB - build HEDIT.COM (VT100/ANSI mono).
; Self-contained: rebuilds HEPATCH.COM first, so the .SUB
; can be run on a fresh disk without any prior setup.
M80 =HEPATCH
L80 HEPATCH,HEPATCH/N/E
HEPATCH 0
ERA *.REL
M80 =HEDIT
M80 =HEXSCR
M80 =HEXKEY
M80 =HEXGAP
M80 =HEXIO
M80 =HEXMENU
M80 =HEXSRCH
M80 =HEXBLK
M80 =HEXKBND
M80 =HEXVIRT
M80 =HEXHELP
L80 HEDIT,HEXSCR,HEXKEY,HEXGAP,HEXIO,HEXMENU,HEXSRCH,HEXBLK,HEXKBND,HEXVIRT,HEXHELP,TEMP/N/E
ERA HEDIT.COM
REN HEDIT.COM=TEMP.COM
