;============================================================
; FILE:    HEXSCR.MAC
; PROJECT: HEDIT - Hex Editor for CP/M 2.2
; VERSION: 1.0
; DATE:    1984-01-01
; AUTHOR:  Claude Code and RetroTechReboot
;------------------------------------------------------------
; DESCRIPTION:
;   VT100/ANSI screen management for hex editor. Handles all
;   terminal I/O: cursor positioning, SGR attributes, hex
;   data row rendering, info bar, column header, separator,
;   and status bar.
;------------------------------------------------------------
; REVISION HISTORY:
;   1.0  1984-01-01  Initial release
;============================================================

;============================================================
; FILE:    HEDIT.INC
; PROJECT: HEDIT - Hex Editor for CP/M 2.2
; VERSION: 1.0
; DATE:    1984-01-01
; AUTHOR:  Claude Code and RetroTechReboot
;------------------------------------------------------------
; DESCRIPTION:
;   Shared equates for all HEDIT modules.
;   INCLUDE this as the first statement of every .MAC file.
;------------------------------------------------------------

;--- CP/M system addresses ----------------------------
BDOS    EQU     0005H       ; BDOS call entry
WBOOT   EQU     0000H       ; warm boot / exit
DFTFCB  EQU     005CH       ; default FCB (arg 1)
CMDTAIL EQU     0080H       ; command tail buffer

;--- BDOS function numbers ----------------------------
BF_CONIN  EQU   1           ; console input (wait)
BF_CONOUT EQU   2           ; console output: E=char
BF_RAWIO  EQU   6           ; direct I/O: E=FFH->in
BF_PRTSTR EQU   9           ; print $-string: DE=addr
BF_RDLINE EQU   10          ; buffered line input
BF_CONST  EQU   11          ; console status
BF_FOPEN  EQU   15          ; open file: DE=FCB
BF_FCLOSE EQU   16          ; close file: DE=FCB
BF_FDEL   EQU   19          ; delete: DE=FCB
BF_FREAD  EQU   20          ; seq read: DE=FCB
BF_FWRITE EQU   21          ; seq write: DE=FCB
BF_FMAKE  EQU   22          ; create: DE=FCB
BF_SETDMA EQU   26          ; set DMA: DE=addr
BF_USRNUM EQU   32          ; get/set user: E=num
BF_CURDSK EQU   25          ; get current disk

;--- FCB field offsets --------------------------------
FCB_DR  EQU     0           ; drive (0=default, 1=A, etc.)
FCB_F1  EQU     1           ; filename (8 bytes)
FCB_T1  EQU     9           ; extension (3 bytes)
FCB_EX  EQU     12          ; extent number
FCB_RC  EQU     15          ; record count
FCB_CR  EQU     32          ; current record

;--- ASCII control codes ------------------------------
NUL     EQU     00H
BEL     EQU     07H         ; bell
BS      EQU     08H         ; backspace
TAB     EQU     09H         ; horizontal tab
LF      EQU     0AH         ; line feed
CR      EQU     0DH         ; carriage return
ESC     EQU     1BH         ; escape
DEL     EQU     7FH         ; delete character
CPMEOF  EQU     1AH         ; CP/M EOF marker (Ctrl-Z)
CTRLK   EQU     0BH         ; Ctrl-K (prefix key)
CTRLQ   EQU     11H         ; Ctrl-Q (prefix key)

;--- Screen layout ------------------------------------
SCRROWS EQU     24          ; terminal row count
SCRCOLS EQU     80          ; terminal column count
EDITROW EQU     20          ; hex data rows (rows 3-22)
EDITFR  EQU     3           ; first edit row (1-based)
INFOROW EQU     1           ; info bar row
HDRROW  EQU     2           ; column header row
SEPRROW EQU     23          ; separator (===) row
STATROW EQU     24          ; status/message row

;--- Hex display layout -------------------------------
BYTESROW EQU    16          ; bytes per display row
BYTESPG EQU     320         ; bytes per page (EDITROW*BYTESROW)
HEXFCOL EQU     7           ; first hex column (1-based)
ASCFCOL EQU     58          ; first ASCII column (1-based)
GRPSEP  EQU     31          ; column of group separator space
ADDRWID EQU     6           ; width of "XXXX: " address field

;--- Hex input modes ----------------------------------
MODE_HEX EQU   0           ; editing in hex field
MODE_ASC EQU   1           ; editing in ASCII field
MODE_OVR EQU   0           ; overwrite mode
MODE_INS EQU   1           ; insert mode

;--- SGR attribute byte values ------------------------
ATTR_NRM EQU    00H         ; normal
ATTR_BLD EQU    01H         ; bold
ATTR_DIM EQU    02H         ; dim
ATTR_REV EQU    07H         ; reverse video
ATTR_CYN EQU    36H         ; cyan foreground
ATTR_GRN EQU    32H         ; green foreground
ATTR_YEL EQU    33H         ; yellow foreground
ATTR_MAG EQU    35H         ; magenta foreground
ATTR_RED EQU    31H         ; red foreground
ATTR_BLU EQU    34H         ; blue foreground

;--- Buffer descriptor field offsets ------------------
BD_BSTAR EQU    0           ; 2: buffer base address
BD_BSIZE EQU    2           ; 2: capacity in bytes
BD_GAPBG EQU    4           ; 2: gap start offset
BD_GAPEN EQU    6           ; 2: gap end offset
BD_TXEND EQU    8           ; 2: logical data length
BD_TOPOFF EQU   10          ; 2: top visible byte offset
BD_CSOFF EQU    12          ; 2: cursor byte offset
BD_MRKBG EQU    14          ; 2: block mark start (FFFF=unset)
BD_MRKEN EQU    16          ; 2: block mark end (FFFF=unset)
BD_MODIF EQU    18          ; 1: modified flag
BD_FILEFMT EQU  19          ; 1: file format (0=bin, 1=ihex)
BD_FNAME EQU    20          ; 12: drive + filename + ext
BD_SIZE  EQU    32          ; total descriptor size

;--- File format codes --------------------------------
FMT_BIN EQU     0           ; raw binary
FMT_IHEX EQU    1           ; Intel HEX

;--- Key types (from GETKEY) --------------------------
KT_NONE EQU     0           ; no key
KT_ACT  EQU     1           ; action code
KT_CHAR EQU     2           ; printable character

;--- Action codes -------------------------------------
ACT_NONE  EQU   0
ACT_CURUP EQU   1           ; cursor up (16 bytes)
ACT_CURDN EQU   2           ; cursor down (16 bytes)
ACT_CURLT EQU   3           ; cursor left (1 byte)
ACT_CURRT EQU   4           ; cursor right (1 byte)
ACT_PGUP  EQU   5           ; page up (320 bytes)
ACT_PGDN  EQU   6           ; page down (320 bytes)
ACT_HOME  EQU   7           ; start of row
ACT_END   EQU   8           ; end of row
ACT_FTOP  EQU   9           ; top of file
ACT_FEND  EQU   10          ; end of file
ACT_DELLF EQU   11          ; delete left (backspace)
ACT_DELRT EQU   12          ; delete right
ACT_TOGIN EQU   13          ; toggle ins/ovr
ACT_TOGMD EQU   14          ; toggle hex/ascii mode
ACT_FNDNX EQU   15          ; find next
ACT_FSAVE EQU   16          ; save file
ACT_FEXIT EQU   17          ; exit
ACT_BLKMK EQU   18          ; block mark
ACT_BLKCP EQU   19          ; block copy
ACT_BLKDL EQU   20          ; block delete
ACT_BLKPS EQU   21          ; block paste
ACT_MENU  EQU   22          ; open ESC menu
ACT_DELRW EQU   23          ; delete row (16 bytes)
ACT_MAX   EQU   23          ; highest action code

;--- Miscellaneous ------------------------------------
MINMEM  EQU     9*1024      ; minimum TPA (9 KB)
CLIPMAX EQU     2048        ; clipboard buffer size
SRCHMAX EQU     64          ; max search pattern length
RECSIZ  EQU     128         ; CP/M record size
MAXADDR EQU     0FFFFH      ; max displayable address


        EXTRN   CURBDP          ; current buffer desc ptr
        EXTRN   DIRTY           ; dirty flag
        EXTRN   INSMODE         ; insert/overwrite mode
        EXTRN   EDITMODE        ; hex/ascii edit mode
        EXTRN   NIBBLE          ; 0=high nibble, 1=low nibble
        EXTRN   GBRDBLK         ; read block of bytes
        EXTRN   GBTXEND         ; HL = data length
        EXTRN   GBCSOFF         ; HL = cursor offset

        PUBLIC  SCRINIT         ; init/clear screen
        PUBLIC  SCRDRAW         ; full screen redraw
        PUBLIC  SCREDCL         ; redraw current row only
        PUBLIC  INFOBAR         ; update info bar row
        PUBLIC  CURPOS          ; position HW cursor
        PUBLIC  STATMSG         ; write to status bar
        PUBLIC  STATCLR         ; clear status bar
        PUBLIC  OUTCHAR         ; output one character
        PUBLIC  OUTSTR          ; output $-string
        PUBLIC  CURGOTO         ; goto row,col
        PUBLIC  OUTN4HX         ; output 16-bit hex
        PUBLIC  OUTN2HX         ; output 8-bit hex
        PUBLIC  ISLOAD          ; loading flag

;--- ESC sequence string constants --------------------
ESCSTR:  DB     ESC,'[','$'     ; ESC [  (CSI intro)
HOMSTR:  DB     ESC,'[','H','$' ; cursor home
CLRSTR:  DB     ESC,'[','2','J','$' ; erase screen
CLREOL:  DB     ESC,'[','K','$' ; erase to end of line
HIDCUR:  DB     ESC,'[','?','2','5','l','$' ; hide cursor
SHWCUR:  DB     ESC,'[','?','2','5','h','$' ; show cursor
APPKPD:  DB     ESC,'=','$'     ; application keypad mode
SGRRES:  DB     ESC,'[','0','m','$'  ; SGR reset
SGRBLD:  DB     ESC,'[','0',';','1','m','$'  ; SGR reset+bold
SGRDIM:  DB     ESC,'[','0',';','2','m','$'  ; SGR reset+dim
SGRREV:  DB     ESC,'[','0',';','7','m','$'  ; SGR reset+reverse
SGRBGN:  DB     ESC,'[','0',';','1',';','3','2','m','$' ; bold green
SGRCYN:  DB     ESC,'[','0',';','3','6','m','$' ; cyan
SGRYEL:  DB     ESC,'[','0',';','3','3','m','$' ; yellow

;--- Info bar label strings ---------------------------
IBSZSTR: DB     ' Size:','$'
IBOFSTR: DB     ' Off:','$'
IBINSTR: DB     ' [INS]','$'
IBOVSTR: DB     ' [OVR]','$'
IBHXSTR: DB     ' [HEX]','$'
IBASSTR: DB     ' [ASC]','$'
NAMNMST: DB     '[No Name]','$'
LDNGMST: DB     '[Loading]','$'

;--- Column header string (row 2) ---------------------
COLHDR:  DB     'Offset  00 01 02 03 04 05 06 07'
         DB     '  08 09 0A 0B 0C 0D 0E 0F  ASCII'
         DB     '$'

;--- Hex digit table ----------------------------------
HXTBL:   DB     '0123456789ABCDEF'

;=============================================================
; SCRINIT - Initialize terminal and draw screen chrome.
; Entry:  (none)
; Exit:   Screen cleared and chrome drawn; all regs clobbered
;=============================================================
        CSEG

SCRINIT:
        LXI     D,HIDCUR        ; hide cursor during init
        CALL    OUTSTR
        LXI     D,CLRSTR        ; ESC[2J - clear screen
        CALL    OUTSTR
        LXI     D,HOMSTR        ; ESC[H - cursor home
        CALL    OUTSTR
        LXI     D,APPKPD        ; application keypad mode
        CALL    OUTSTR
        ; Draw column header (row 2)
        CALL    HDRDRAW
        ; Draw separator (row 23)
        CALL    SEPRDRAW
        ; Clear status line (row 24)
        CALL    STATCLR
        ; Set dirty to trigger full redraw
        MVI     A,1
        STA     DIRTY
        LXI     D,SHWCUR
        JMP     OUTSTR

;=============================================================
; HDRDRAW - Draw column header (row 2) in dim attribute.
; Entry:  (none)
; Exit:   All regs clobbered
;=============================================================
HDRDRAW:
        MVI     B,HDRROW
        MVI     C,1
        CALL    CURGOTO
        LXI     D,SGRDIM
        CALL    OUTSTR
        LXI     D,COLHDR
        CALL    OUTSTR
        LXI     D,SGRRES
        CALL    OUTSTR
        LXI     D,CLREOL
        JMP     OUTSTR

;=============================================================
; SEPRDRAW - Draw separator line (row 23): 80 '=' chars, dim.
; Entry:  (none)
; Exit:   All regs clobbered
;=============================================================
SEPRDRAW:
        MVI     B,SEPRROW
        MVI     C,1
        CALL    CURGOTO
        LXI     D,SGRDIM
        CALL    OUTSTR
        MVI     B,SCRCOLS       ; 80 '=' characters
SPRLP:  MVI     A,'='
        PUSH    B
        CALL    OUTCHAR
        POP     B
        DCR     B
        JNZ     SPRLP
        LXI     D,SGRRES
        JMP     OUTSTR

;=============================================================
; SCRDRAW - Full screen redraw of 20 hex data rows.
; Entry:  (none) - uses current buffer via CURBDP
; Exit:   All edit rows redrawn; all regs clobbered
;=============================================================
SCRDRAW:
        ; Read BD_TOPOFF into SDTOPOFF
        LHLD    CURBDP
        LXI     D,BD_TOPOFF
        DAD     D
        MOV     E,M
        INX     H
        MOV     D,M
        XCHG
        SHLD    SDTOPOFF        ; save top offset

        ; Get data length
        CALL    GBTXEND
        SHLD    SDTXEND         ; save for row loop

        MVI     A,0
        STA     SDROW           ; start at row 0

SDLOOP:
        ; Calculate byte offset = TOPOFF + row*16
        LDA     SDROW
        MOV     L,A
        MVI     H,0
        ; Shift left 4 times (multiply by 16)
        DAD     H
        DAD     H
        DAD     H
        DAD     H
        XCHG                    ; DE = row*16
        LHLD    SDTOPOFF
        DAD     D               ; HL = TOPOFF + row*16
        SHLD    SDOFFS          ; save row offset

        ; Check if offset < data length
        XCHG                    ; DE = row offset
        LHLD    SDTXEND         ; HL = data length
        MOV     A,L
        SUB     E
        MOV     A,H
        SBB     D
        JC      SDBLNK          ; offset > length -> blank row
        JZ      SDBLNK          ; offset == length -> blank row (no bytes)

        ; Compute byte count = min(16, length - offset)
        ; DE = row offset, HL = data length
        ; length - offset already known to be > 0
        MOV     A,L
        SUB     E
        MOV     C,A
        MOV     A,H
        SBB     D
        ; If high byte > 0, at least 256 bytes remain -> count = 16
        ORA     A
        JNZ     SDFULL
        ; Low byte C has remaining count
        MOV     A,C
        CPI     BYTESROW
        JNC     SDFULL          ; >= 16 -> full row
        ; Partial row: C = byte count
        JMP     SDREAD

SDFULL: MVI     C,BYTESROW      ; 16 bytes

SDREAD:
        ; Read bytes: offset in SDOFFS, count in C
        MOV     A,C
        STA     SDBCNT          ; save byte count
        LHLD    SDOFFS
        XCHG                    ; DE = offset
        LXI     H,ROWBUF        ; HL = destination
        MOV     B,A             ; B = count
        CALL    GBRDBLK         ; read B bytes from offset DE into HL

        ; Render the row
        LDA     SDROW
        MOV     B,A             ; B = row number (0-based)
        LXI     D,ROWBUF        ; DE = data buffer
        LDA     SDBCNT
        MOV     C,A             ; C = byte count
        CALL    SCRHROW
        JMP     SDNEXT

SDBLNK:
        ; Blank row: position and clear
        LDA     SDROW
        ADI     EDITFR          ; screen row (1-based)
        MOV     B,A
        MVI     C,1
        CALL    CURGOTO
        LXI     D,CLREOL
        CALL    OUTSTR

SDNEXT:
        LDA     SDROW
        INR     A
        STA     SDROW
        CPI     EDITROW
        JC      SDLOOP          ; loop for 20 rows

        ; Clear status line
        CALL    STATCLR
        RET

;=============================================================
; SCREDCL - Redraw current row only.
; Calculates which row the cursor is on and redraws it.
; Entry:  (none)
; Exit:   All regs clobbered
;=============================================================
SCREDCL:
        ; Get cursor offset
        CALL    GBCSOFF
        SHLD    SDOFFS          ; cursor offset

        ; Get top offset
        LHLD    CURBDP
        LXI     D,BD_TOPOFF
        DAD     D
        MOV     E,M
        INX     H
        MOV     D,M
        XCHG
        SHLD    SDTOPOFF

        ; row = (CSOFF - TOPOFF) / 16
        LHLD    SDOFFS          ; HL = cursor offset
        XCHG                    ; DE = cursor offset
        LHLD    SDTOPOFF        ; HL = top offset
        MOV     A,E
        SUB     L
        MOV     L,A
        MOV     A,D
        SBB     H
        MOV     H,A             ; HL = CSOFF - TOPOFF
        ; Divide by 16: shift right 4 times
        MOV     A,H
        RAR
        MOV     A,L
        RAR
        RAR
        RAR
        RAR
        ANI     0FH             ; A = row (0-19)
        ; If high byte was set, need full calculation
        ; But with 20 rows * 16 bytes = 320 max, high byte can be 1
        ; Full division: HL / 16
        PUSH    H               ; save offset diff
        ; Recalculate: use H*16 + shift of L
        POP     H
        ; Shift HL right 4 times
        MOV     A,H
        RRC
        RRC
        RRC
        RRC
        ANI     0F0H            ; high nibble of H shifted to bits 7-4
        MOV     B,A             ; save
        MOV     A,L
        RRC
        RRC
        RRC
        RRC
        ANI     0FH             ; low nibble of L shifted right 4
        ORA     B               ; combine
        ; A = row number (0-based)
        STA     SDROW

        ; Calculate row's starting offset (aligned to 16)
        ; rowoff = TOPOFF + row*16
        MOV     L,A
        MVI     H,0
        DAD     H
        DAD     H
        DAD     H
        DAD     H               ; HL = row*16
        XCHG
        LHLD    SDTOPOFF
        DAD     D               ; HL = aligned row offset
        SHLD    SDOFFS

        ; Get data length for count calculation
        CALL    GBTXEND
        SHLD    SDTXEND

        ; Compute byte count
        XCHG                    ; DE = txend
        LHLD    SDOFFS          ; HL = row offset
        ; count = min(16, txend - rowoff)
        MOV     A,E
        SUB     L
        MOV     C,A
        MOV     A,D
        SBB     H
        JC      SCBLNK          ; rowoff > txend -> blank
        ORA     A
        JNZ     SCFULL          ; high byte > 0 -> at least 256 remain
        MOV     A,C
        ORA     A
        JZ      SCBLNK          ; exactly 0 bytes
        CPI     BYTESROW
        JNC     SCFULL
        ; Partial: C = count
        JMP     SCRDRD

SCFULL: MVI     C,BYTESROW

SCRDRD:
        ; Read bytes into ROWBUF
        MOV     A,C
        STA     SDBCNT
        LHLD    SDOFFS
        XCHG                    ; DE = offset
        LXI     H,ROWBUF
        MOV     B,A             ; B = count
        CALL    GBRDBLK

        ; Render
        LDA     SDROW
        MOV     B,A
        LXI     D,ROWBUF
        LDA     SDBCNT
        MOV     C,A
        JMP     SCRHROW

SCBLNK:
        ; Blank row
        LDA     SDROW
        ADI     EDITFR
        MOV     B,A
        MVI     C,1
        CALL    CURGOTO
        LXI     D,CLREOL
        JMP     OUTSTR

;=============================================================
; SCRHROW - Render one hex data row.
; Entry:  B = row number (0-based, relative to edit area)
;         DE = data buffer address
;         C = byte count (0-16)
; Exit:   All regs clobbered
;=============================================================
SCRHROW:
        MOV     A,B
        STA     SHROW           ; save row number
        MOV     A,C
        STA     SHCNT           ; save byte count
        XCHG
        SHLD    SHBUF           ; save buffer address

        ; Position cursor at start of row
        LDA     SHROW
        ADI     EDITFR          ; convert to 1-based screen row
        MOV     B,A
        MVI     C,1
        CALL    CURGOTO

        ;--- Address field: bold green ---
        LXI     D,SGRBGN        ; bold green
        CALL    OUTSTR

        ; Calculate address = TOPOFF + row*16
        LDA     SHROW
        MOV     L,A
        MVI     H,0
        DAD     H
        DAD     H
        DAD     H
        DAD     H               ; HL = row*16
        XCHG
        LHLD    SDTOPOFF
        DAD     D               ; HL = address
        CALL    OUTN4HX         ; output 4 hex digits

        ; ": " separator
        LXI     D,SGRRES
        CALL    OUTSTR
        MVI     A,':'
        CALL    OUTCHAR
        MVI     A,' '
        CALL    OUTCHAR

        ;--- Hex bytes: cyan ---
        LXI     D,SGRCYN
        CALL    OUTSTR

        ; Output 16 hex byte positions
        MVI     A,0
        STA     SHIDX           ; byte index

SHHXLP:
        LDA     SHIDX
        CPI     BYTESROW
        JZ      SHHXDN          ; done all 16 positions

        ; Group separator between byte 7 and 8
        CPI     8
        JNZ     SHNOSP
        MVI     A,' '
        CALL    OUTCHAR
SHNOSP:
        ; Check if this byte exists
        LDA     SHIDX
        MOV     B,A
        LDA     SHCNT
        CMP     B               ; count - index
        JZ      SHEMPT          ; index == count: empty
        JC      SHEMPT          ; index > count: empty

        ; Output hex byte
        LHLD    SHBUF
        LDA     SHIDX
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A             ; HL -> byte
        MOV     A,M             ; A = byte value
        CALL    OUTN2HX         ; output 2 hex digits
        MVI     A,' '
        CALL    OUTCHAR
        JMP     SHNXHX

SHEMPT:
        ; Empty position: "   " (3 spaces)
        MVI     A,' '
        CALL    OUTCHAR
        MVI     A,' '
        CALL    OUTCHAR
        MVI     A,' '
        CALL    OUTCHAR

SHNXHX:
        LDA     SHIDX
        INR     A
        STA     SHIDX
        JMP     SHHXLP

SHHXDN:
        ;--- Gap between hex and ASCII ---
        LXI     D,SGRRES
        CALL    OUTSTR
        MVI     A,' '
        CALL    OUTCHAR

        ;--- ASCII column: yellow ---
        LXI     D,SGRYEL
        CALL    OUTSTR

        MVI     A,0
        STA     SHIDX

SHASCLP:
        LDA     SHIDX
        MOV     B,A
        LDA     SHCNT
        CMP     B
        JZ      SHASCDN         ; no more bytes
        JC      SHASCDN

        ; Get byte value
        LHLD    SHBUF
        LDA     SHIDX
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        MOV     A,M

        ; Printable range: 20H-7EH shown as-is, others as '.'
        CPI     20H
        JC      SHDOT
        CPI     7FH
        JNC     SHDOT
        ; Printable character
        JMP     SHASCOUT

SHDOT:  MVI     A,'.'

SHASCOUT:
        CALL    OUTCHAR
        LDA     SHIDX
        INR     A
        STA     SHIDX
        JMP     SHASCLP

SHASCDN:
        ; Reset attributes and clear to EOL
        LXI     D,SGRRES
        CALL    OUTSTR
        LXI     D,CLREOL
        JMP     OUTSTR

;=============================================================
; INFOBAR - Update info bar (row 1).
; Shows: drive+filename, Size:XXXX, Off:XXXX, [INS]/[OVR],
;        [HEX]/[ASC]
; Entry:  (none)
; Exit:   All regs clobbered
;=============================================================
INFOBAR:
        MVI     B,INFOROW
        MVI     C,1
        CALL    CURGOTO
        LXI     D,SGRREV        ; reverse video for info bar
        CALL    OUTSTR

        ; Check loading flag
        LDA     ISLOAD
        ORA     A
        JNZ     IBLDNG

        ;--- Drive letter ---
        LHLD    CURBDP
        LXI     D,BD_FNAME
        DAD     D               ; HL -> BD_FNAME
        MOV     A,M             ; drive byte
        ORA     A
        JZ      IBDDEF          ; 0 = default drive
        ADI     'A'-1           ; 1=A, 2=B, etc.
        JMP     IBDOUT
IBDDEF:
        ; Get current drive from BDOS
        MVI     C,BF_CURDSK
        CALL    BDOS
        ; BDOS returns current disk in A (0=A, 1=B, ...)
        ADI     'A'
IBDOUT:
        CALL    OUTCHAR
        MVI     A,':'
        CALL    OUTCHAR

        ;--- Filename (8 chars) ---
        ; Copy 8 filename bytes to local buffer, then output
        ; (avoids save/restore HL across each OUTCHAR/BDOS call)
        LHLD    CURBDP
        LXI     D,BD_FNAME+1    ; skip drive byte
        DAD     D               ; HL -> filename
        MVI     B,8
        LXI     D,IBFNTMP       ; local copy buffer
IBFCPY: MOV     A,M
        STAX    D
        INX     H
        INX     D
        DCR     B
        JNZ     IBFCPY
        ; Now output from local buffer, skipping trailing spaces
        ; First find last non-space
        LXI     H,IBFNTMP+7     ; last char
        MVI     B,8
IBFTRM: MOV     A,M
        CPI     ' '
        JNZ     IBFOUT
        DCX     H
        DCR     B
        JNZ     IBFTRM
        JMP     IBEXT           ; all spaces -> no name
IBFOUT:
        ; B = number of chars to output (including trailing non-space)
        MOV     A,B
        STA     IBFNCNT
        LXI     H,IBFNTMP
        SHLD    IBFNPTR
IBFNLP: LHLD    IBFNPTR
        MOV     A,M             ; get next char
        INX     H
        SHLD    IBFNPTR         ; save updated pointer
        CALL    OUTCHAR         ; BDOS clobbers all regs
        LDA     IBFNCNT
        DCR     A
        STA     IBFNCNT
        JNZ     IBFNLP

IBEXT:
        ;--- Extension ---
        ; Copy 3 extension bytes to local buffer
        LHLD    CURBDP
        LXI     D,BD_FNAME+9    ; drive(1) + name(8)
        DAD     D
        MOV     A,M
        STA     IBEXTMP
        INX     H
        MOV     A,M
        STA     IBEXTMP+1
        INX     H
        MOV     A,M
        STA     IBEXTMP+2

        ; Check if extension is blank
        LDA     IBEXTMP
        CPI     ' '
        JZ      IBNOEX
        ; Output ".ext"
        MVI     A,'.'
        CALL    OUTCHAR
        LDA     IBEXTMP
        CALL    OUTCHAR
        LDA     IBEXTMP+1
        CPI     ' '
        JZ      IBNOEX
        CALL    OUTCHAR
        LDA     IBEXTMP+2
        CPI     ' '
        JZ      IBNOEX
        CALL    OUTCHAR
IBNOEX:
        JMP     IBSIZE

IBLDNG:
        ; Loading mode: show "[Loading]"
        LXI     D,LDNGMST
        CALL    OUTSTR

IBSIZE:
        ;--- Size: XXXX ---
        LXI     D,IBSZSTR
        CALL    OUTSTR
        CALL    GBTXEND         ; HL = data length
        CALL    OUTN4HX

        ;--- Off: XXXX ---
        LXI     D,IBOFSTR
        CALL    OUTSTR
        CALL    GBCSOFF         ; HL = cursor offset
        CALL    OUTN4HX

        ;--- [INS] or [OVR] ---
        LDA     INSMODE
        ORA     A
        JZ      IBOVR
        LXI     D,IBINSTR
        JMP     IBIOOUT
IBOVR:  LXI     D,IBOVSTR
IBIOOUT:
        CALL    OUTSTR

        ;--- [HEX] or [ASC] ---
        LDA     EDITMODE
        ORA     A
        JNZ     IBASC
        LXI     D,IBHXSTR
        JMP     IBHAOUT
IBASC:  LXI     D,IBASSTR
IBHAOUT:
        CALL    OUTSTR

        ;--- Pad rest of info bar with spaces, clear to EOL ---
        LXI     D,SGRRES
        CALL    OUTSTR
        LXI     D,CLREOL
        JMP     OUTSTR

;=============================================================
; CURPOS - Position hardware cursor in hex or ASCII field.
; Entry:  (none)
; Exit:   Cursor positioned; all regs clobbered
;=============================================================
CURPOS:
        ; Get cursor offset
        CALL    GBCSOFF
        SHLD    CPTMP1          ; save CSOFF

        ; Get top offset
        LHLD    CURBDP
        LXI     D,BD_TOPOFF
        DAD     D
        MOV     E,M
        INX     H
        MOV     D,M
        XCHG
        SHLD    CPTMP2          ; save TOPOFF

        ; Calculate offset within visible area
        LHLD    CPTMP1          ; HL = CSOFF
        XCHG                    ; DE = CSOFF
        LHLD    CPTMP2          ; HL = TOPOFF
        MOV     A,E
        SUB     L
        MOV     L,A
        MOV     A,D
        SBB     H
        MOV     H,A             ; HL = CSOFF - TOPOFF

        ; byte_in_row = low_byte AND 0FH
        MOV     A,L
        ANI     0FH
        STA     CPBYTE          ; save byte_in_row

        ; row = (CSOFF - TOPOFF) / 16
        ; Shift HL right 4 times
        MOV     A,H
        RRC
        RRC
        RRC
        RRC
        ANI     0F0H
        MOV     B,A
        MOV     A,L
        RRC
        RRC
        RRC
        RRC
        ANI     0FH
        ORA     B               ; A = row (0-based)
        ADI     EDITFR          ; convert to 1-based screen row
        MOV     B,A             ; B = screen row

        ; Determine column based on edit mode
        LDA     EDITMODE
        ORA     A
        JNZ     CPASCM          ; ASCII mode

        ;--- HEX mode column ---
        ; col = HEXFCOL + (byte_in_row * 3) + nibble + group_gap
        LDA     CPBYTE
        ; byte_in_row * 3
        MOV     C,A             ; save byte_in_row
        ADD     A               ; *2
        ADD     C               ; *3
        ADI     HEXFCOL         ; + first hex column

        ; Add group gap if byte >= 8
        PUSH    PSW             ; save col so far
        MOV     A,C             ; byte_in_row
        CPI     8
        JC      CPNOGP          ; < 8, no gap
        POP     PSW
        INR     A               ; +1 for group separator
        PUSH    PSW
CPNOGP:
        POP     PSW             ; A = col before nibble

        ; Add nibble offset
        PUSH    PSW
        LDA     NIBBLE
        MOV     C,A             ; C = nibble (0 or 1)
        POP     PSW
        ADD     C               ; + nibble offset
        MOV     C,A             ; C = final column
        JMP     CPGOTO

CPASCM:
        ;--- ASCII mode column ---
        ; col = ASCFCOL + byte_in_row
        LDA     CPBYTE
        ADI     ASCFCOL
        MOV     C,A             ; C = column

CPGOTO:
        ; B = row (1-based), C = col (1-based)
        JMP     CURGOTO

;=============================================================
; STATMSG - Display status message.
; Entry:  DE = $-terminated string
; Exit:   Message shown on row 24; all regs clobbered
;=============================================================
STATMSG:
        PUSH    D               ; save message pointer
        MVI     B,STATROW
        MVI     C,1
        CALL    CURGOTO
        POP     D
        CALL    OUTSTR
        LXI     D,CLREOL
        JMP     OUTSTR

;=============================================================
; STATCLR - Clear status line (row 24).
; Entry:  (none)
; Exit:   All regs clobbered
;=============================================================
STATCLR:
        MVI     B,STATROW
        MVI     C,1
        CALL    CURGOTO
        LXI     D,CLREOL
        JMP     OUTSTR

;=============================================================
; OUTCHAR - Output single character to console.
; Entry:  A = character
; Exit:   Character sent; AF BC DE HL clobbered (BDOS)
;=============================================================
OUTCHAR:
        MOV     E,A
        MVI     C,BF_RAWIO
        JMP     BDOS

;=============================================================
; OUTSTR - Output '$'-terminated string to console.
; Entry:  DE = string address
; Exit:   String sent; AF BC DE HL clobbered
;=============================================================
OUTSTR:
        LDAX    D               ; A = next char
        CPI     '$'
        RZ                      ; end of string
        PUSH    D               ; save string pointer
        MOV     E,A
        MVI     C,BF_RAWIO
        CALL    BDOS
        POP     D               ; restore string pointer
        INX     D
        JMP     OUTSTR

;=============================================================
; CURGOTO - Position cursor at B=row, C=col (1-based).
; Outputs ESC[row;colH
; Entry:  B = row (1-based), C = col (1-based)
; Exit:   All regs clobbered
;=============================================================
CURGOTO:
        PUSH    B               ; save row(B) col(C)
        LXI     D,ESCSTR        ; output "ESC["
        CALL    OUTSTR
        POP     B               ; restore
        PUSH    B               ; save col
        ; Output row as decimal
        XRA     A
        STA     CGLFLAG         ; reset leading-zero flag
        MOV     L,B
        MVI     H,0
        CALL    CGOUTHL         ; output row digits
        MVI     A,';'
        CALL    OUTCHAR
        POP     B               ; restore col
        XRA     A
        STA     CGLFLAG
        MOV     L,C
        MVI     H,0
        CALL    CGOUTHL         ; output col digits
        MVI     A,'H'
        JMP     OUTCHAR

;--- CGOUTHL: output HL as decimal (suppress leading zeros) ---
CGOUTHL:
        LXI     D,100
        CALL    CGDGT
        LXI     D,10
        CALL    CGDGT
        MOV     A,L
        ADI     '0'
        JMP     OUTCHAR

;--- CGDGT: divide HL by DE, output digit ---
CGDGT:
        MVI     B,0FFH
CGDSUB: INR     B
        MOV     A,L
        SUB     E
        MOV     L,A
        MOV     A,H
        SBB     D
        MOV     H,A
        JNC     CGDSUB
        DAD     D               ; restore remainder
        MOV     A,B             ; digit
        ORA     A
        JNZ     CGDYES
        LDA     CGLFLAG
        ORA     A
        RZ                      ; leading zero: suppress
        MVI     A,'0'
        PUSH    H
        CALL    OUTCHAR
        POP     H
        RET
CGDYES: STA     CGLFLAG         ; mark digit seen
        ADI     '0'
        PUSH    H
        CALL    OUTCHAR
        POP     H
        RET

;=============================================================
; OUTN4HX - Output 16-bit value in HL as 4 hex digits.
; Entry:  HL = value
; Exit:   All regs clobbered
;=============================================================
OUTN4HX:
        ; High byte first
        MOV     A,H
        PUSH    H               ; save HL (BDOS clobbers)
        CALL    OUTN2HX
        POP     H
        ; Low byte
        MOV     A,L
        JMP     OUTN2HX

;=============================================================
; OUTN2HX - Output 8-bit value in A as 2 hex digits.
; Entry:  A = byte value
; Exit:   All regs clobbered
;=============================================================
OUTN2HX:
        STA     HXTMP           ; save byte
        ; High nibble
        RRC
        RRC
        RRC
        RRC
        ANI     0FH
        CALL    HEXDIG          ; output high nibble
        ; Low nibble
        LDA     HXTMP
        ANI     0FH
        JMP     HEXDIG          ; output low nibble (tail call)

;--- HEXDIG: output nibble in A (0-15) as hex character ---
HEXDIG:
        CPI     10
        JC      HXDEC           ; 0-9
        ADI     'A'-10          ; A-F
        JMP     OUTCHAR
HXDEC:  ADI     '0'             ; 0-9
        JMP     OUTCHAR

;=============================================================
; DSEG - Working variables
;=============================================================
        DSEG

ROWBUF:  DS     16              ; buffer for one row of data
SDROW:   DB     0               ; current draw row (0-based)
SDTOPOFF: DW    0               ; saved TOPOFF for draw loop
SDTXEND: DW     0               ; saved data length
SDOFFS:  DW     0               ; current row byte offset
SDBCNT:  DB     0               ; byte count for current row
SHROW:   DB     0               ; SCRHROW: row number
SHCNT:   DB     0               ; SCRHROW: byte count
SHBUF:   DW     0               ; SCRHROW: buffer address
SHIDX:   DB     0               ; SCRHROW: byte index
CPBYTE:  DB     0               ; CURPOS: byte_in_row
CPTMP1:  DW     0               ; CURPOS: cursor offset
CPTMP2:  DW     0               ; CURPOS: top offset
CGLFLAG: DB     0               ; CURGOTO: leading-zero flag
HXTMP:   DB     0               ; OUTN2HX: saved byte
ISLOAD:  DB     0               ; non-zero during file loading
IBFNTMP: DS     8               ; INFOBAR: filename copy buffer
IBEXTMP: DS     3               ; INFOBAR: extension copy buffer
IBFNPTR: DW     0               ; INFOBAR: filename output pointer
IBFNCNT: DB     0               ; INFOBAR: filename output counter

        END
