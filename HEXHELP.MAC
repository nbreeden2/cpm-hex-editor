;============================================================
; FILE:    HEXHELP.MAC
; PROJECT: HEDIT - Hex Editor for CP/M 2.2
; VERSION: 1.04
; DATE:    1984-01-01
; AUTHOR:  Claude Code and RetroTechReboot
;------------------------------------------------------------
; DESCRIPTION:
;   Help screen display. HLPSHOW draws a two-column help
;   reference overlay, waits for any key, then returns.
;   The overlay uses reverse-video for the header and footer
;   lines and normal text for the body. Covers rows 1-24.
;
;   Terminal-agnostic: uses ATTRON/ATROFF/CLRTOE/CURGOTO
;   exported by the screen driver module. No hardcoded
;   escape sequences.
;
;   IMPORTANT: This module MUST be linked last. BMDATEND
;   marks the end of all static code/data and serves as the
;   gap buffer base address. L80 lays out [DSEG][CSEG] per
;   module, so BMDATEND in CSEG captures all addresses.
;------------------------------------------------------------
; REVISION HISTORY:
;   1.0  1984-01-01  Initial release
;============================================================

        INCLUDE HEDIT.INC

;--- Imports ----------------------------------------------
        EXTRN   OUTSTR          ; write $-string to console
        EXTRN   OUTCHAR         ; write single char
        EXTRN   CURGOTO         ; position cursor (B=row,C=col)
        EXTRN   DIRTY           ; full redraw flag
        EXTRN   ATTRON          ; reverse video on ($-string)
        EXTRN   ATROFF          ; reverse video off ($-string)
        EXTRN   CLRTOE          ; clear to end of line ($-string)
        EXTRN   SCRINIT         ; clear screen + draw chrome
        EXTRN   RSTAT           ; runtime status row

;--- Exports ----------------------------------------------
        PUBLIC  HLPSHOW         ; show help and wait
        PUBLIC  BMDATEND        ; end-of-data marker (must link last)

;=============================================================
; HLPSHOW - Display help screen, wait for keypress, return.
; Entry:  (none)
; Exit:   Screen dirty (caller sets DIRTY flag).
;         All regs clobbered.
;=============================================================
        CSEG

HLPSHOW:
        ; Clear screen: reset attr, erase, home
        LXI     D,ATROFF
        CALL    OUTSTR
        MVI     B,1
        MVI     C,1
        CALL    CURGOTO         ; home cursor
        ; Erase each row with spaces (terminal-agnostic)
        MVI     A,SCRROWS
        STA     HLPCNT
HLPCLS: MVI     A,' '
        MVI     B,SCRCOLS
HLPCL2: PUSH    B
        PUSH    PSW
        CALL    OUTCHAR
        POP     PSW
        POP     B
        DCR     B
        JNZ     HLPCL2
        LDA     HLPCNT
        DCR     A
        STA     HLPCNT
        JNZ     HLPCLS

        ; Draw header (row 1, reverse video, full width)
        MVI     B,1
        MVI     C,1
        CALL    CURGOTO
        LXI     D,ATTRON
        CALL    OUTSTR
        LXI     D,HLPHDR
        CALL    OUTSTR
        ; Pad header to 80 cols with spaces
        MVI     B,SCRCOLS-HLPHDL
HLPHPD: MVI     A,' '
        PUSH    B
        CALL    OUTCHAR
        POP     B
        DCR     B
        JNZ     HLPHPD
        LXI     D,ATROFF
        CALL    OUTSTR

        ; Draw help lines (rows 3-24, 2 columns)
        ; Index stored in HLPIDX (registers clobbered by calls)
        XRA     A
        STA     HLPIDX

HLPLP:  LDA     HLPIDX
        CPI     HLPLINES
        JNC     HLPWAIT

        ; Position left column (row = index + 3, col = 1)
        ADI     3
        MOV     B,A
        MVI     C,1
        CALL    CURGOTO

        ; Get left text pointer from table
        LDA     HLPIDX
        MOV     L,A
        MVI     H,0
        DAD     H               ; *2
        LXI     D,HLPLTBL
        DAD     D
        MOV     E,M
        INX     H
        MOV     D,M
        CALL    OUTSTR

        ; Position right column (row = index + 3, col = 41)
        LDA     HLPIDX
        ADI     3
        MOV     B,A
        MVI     C,41
        CALL    CURGOTO

        ; Get right text pointer from table
        LDA     HLPIDX
        MOV     L,A
        MVI     H,0
        DAD     H
        LXI     D,HLPRTBL
        DAD     D
        MOV     E,M
        INX     H
        MOV     D,M
        CALL    OUTSTR

        ; Increment index
        LDA     HLPIDX
        INR     A
        STA     HLPIDX
        JMP     HLPLP

HLPWAIT:
        ; Footer prompt at row 24
        LDA     RSTAT           ; B = runtime status row
        MOV     B,A
        MVI     C,1
        CALL    CURGOTO
        LXI     D,ATTRON
        CALL    OUTSTR
        LXI     D,HLPFTR
        CALL    OUTSTR
        ; Pad footer to 80 cols
        MVI     B,SCRCOLS-HLPFTL
HLPFPD: MVI     A,' '
        PUSH    B
        CALL    OUTCHAR
        POP     B
        DCR     B
        JNZ     HLPFPD
        LXI     D,ATROFF
        CALL    OUTSTR

        ; Drain any buffered keyboard input so a stale
        ; keystroke from the menu cannot dismiss help instantly
HLPDRN: MVI     E,0FFH
        MVI     C,BF_RAWIO
        CALL    BDOS
        ORA     A
        JNZ     HLPDRN          ; keep draining

        ; Wait for a fresh keypress (non-blocking poll)
HLPKEY: MVI     E,0FFH
        MVI     C,BF_RAWIO
        CALL    BDOS
        ORA     A
        JZ      HLPKEY          ; no char yet, keep polling

        ; Clear the footer line before returning
        LDA     RSTAT           ; B = runtime status row
        MOV     B,A
        MVI     C,1
        CALL    CURGOTO
        LXI     D,CLRTOE
        CALL    OUTSTR
        LXI     D,ATROFF
        CALL    OUTSTR

        ; Set dirty flag so caller redraws
        MVI     A,1
        STA     DIRTY
        RET

;=============================================================
; String constants (no escape sequences - terminal agnostic)
;=============================================================

HLPHDR:  DB     ' HEDIT v1.04 Key Reference$'
HLPHDL  EQU     27              ; length of HLPHDR (excluding $)
HLPFTR:  DB     ' Press any key to return...$'
HLPFTL  EQU     27              ; length of HLPFTR (excluding $)

; Left column lines (40 chars max each, $-terminated)
HLL01:  DB  ' NAVIGATION                $'
HLL02:  DB  ' Up/^E    Up 16 bytes      $'
HLL03:  DB  ' Down/^X  Down 16 bytes    $'
HLL04:  DB  ' Left/^S  Left 1 byte      $'
HLL05:  DB  ' Right/^D Right 1 byte     $'
HLL06:  DB  ' PgUp/^R  Up 320 bytes     $'
HLL07:  DB  ' PgDn/^C  Down 320 bytes   $'
HLL08:  DB  ' Home/^QS Start of row     $'
HLL09:  DB  ' End/^QD  End of row       $'
HLL10:  DB  ' ^QR      Top of file      $'
HLL11:  DB  ' ^QC      End of file      $'
HLL12:  DB  '                           $'
HLL13:  DB  '                           $'
HLL14:  DB  '                           $'
HLL15:  DB  '                           $'

; Right column lines
HLR01:  DB  ' EDITING                   $'
HLR02:  DB  ' 0-9,A-F  Hex byte input   $'
HLR03:  DB  ' Tab/^I   Toggle HEX/ASCII $'
HLR04:  DB  ' ^V/Ins   Toggle INS/OVR   $'
HLR05:  DB  ' BS/^H    Delete left       $'
HLR06:  DB  ' Del/^G   Delete right      $'
HLR07:  DB  ' ^Y       Delete row (16B)  $'
HLR08:  DB  ' ^KB/F3   Block mark        $'
HLR09:  DB  ' ^KC      Block copy        $'
HLR10:  DB  ' ^KD      Block delete      $'
HLR11:  DB  ' ^KP      Block paste       $'
HLR12:  DB  ' ^KS/F2   Save file         $'
HLR13:  DB  ' ^L/F1    Find next         $'
HLR14:  DB  ' ESC/F4   Menu              $'
HLR15:  DB  '                           $'

HLPLINES EQU    15              ; number of help line pairs

; Pointer tables in CSEG: immune to DSEG corruption from
; gap buffer or other data operations.
; Left column text pointer table (word per line)
HLPLTBL:
        DW      HLL01
        DW      HLL02
        DW      HLL03
        DW      HLL04
        DW      HLL05
        DW      HLL06
        DW      HLL07
        DW      HLL08
        DW      HLL09
        DW      HLL10
        DW      HLL11
        DW      HLL12
        DW      HLL13
        DW      HLL14
        DW      HLL15

; Right column text pointer table
HLPRTBL:
        DW      HLR01
        DW      HLR02
        DW      HLR03
        DW      HLR04
        DW      HLR05
        DW      HLR06
        DW      HLR07
        DW      HLR08
        DW      HLR09
        DW      HLR10
        DW      HLR11
        DW      HLR12
        DW      HLR13
        DW      HLR14
        DW      HLR15

;------------------------------------------------------------
; BMDATEND - marks the end of all static data.
; This MUST be in CSEG at the very end of the last-linked
; module, because L80 lays out [DSEG][CSEG] per module.
; Placing it in DSEG would miss HEXHELP's CSEG content
; (HLPSHOW code, help strings, pointer tables), and the
; gap buffer starting at BMDATEND would overwrite them.
;------------------------------------------------------------
BMDATEND EQU    $

;=============================================================
; DATA SEGMENT
;=============================================================
        DSEG

; Loop index and counter for help display
HLPIDX: DB      0
HLPCNT: DB      0

        END
