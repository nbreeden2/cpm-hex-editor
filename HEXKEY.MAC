;============================================================
; FILE:    HEXKEY.MAC
; PROJECT: HEDIT - Hex Editor for CP/M 2.2
; VERSION: 1.0
; DATE:    1984-01-01
; AUTHOR:  Claude Code and RetroTechReboot
;------------------------------------------------------------
; DESCRIPTION:
;   Key input and decoding for the hex editor. Reads raw
;   bytes from the console, decodes VT100 escape sequences,
;   Ctrl-K/Ctrl-Q prefixes, and returns action codes or
;   characters to the main loop.
;------------------------------------------------------------
; REVISION HISTORY:
;   1.0  1984-01-01  Initial release
;============================================================

;============================================================
; FILE:    HEDIT.INC
; PROJECT: HEDIT - Hex Editor for CP/M 2.2
; VERSION: 1.0
; DATE:    1984-01-01
; AUTHOR:  Claude Code and RetroTechReboot
;------------------------------------------------------------
; DESCRIPTION:
;   Shared equates for all HEDIT modules.
;   INCLUDE this as the first statement of every .MAC file.
;------------------------------------------------------------

;--- CP/M system addresses ----------------------------
BDOS    EQU     0005H       ; BDOS call entry
WBOOT   EQU     0000H       ; warm boot / exit
DFTFCB  EQU     005CH       ; default FCB (arg 1)
CMDTAIL EQU     0080H       ; command tail buffer

;--- BDOS function numbers ----------------------------
BF_CONIN  EQU   1           ; console input (wait)
BF_CONOUT EQU   2           ; console output: E=char
BF_RAWIO  EQU   6           ; direct I/O: E=FFH->in
BF_PRTSTR EQU   9           ; print $-string: DE=addr
BF_RDLINE EQU   10          ; buffered line input
BF_CONST  EQU   11          ; console status
BF_FOPEN  EQU   15          ; open file: DE=FCB
BF_FCLOSE EQU   16          ; close file: DE=FCB
BF_FDEL   EQU   19          ; delete: DE=FCB
BF_FREAD  EQU   20          ; seq read: DE=FCB
BF_FWRITE EQU   21          ; seq write: DE=FCB
BF_FMAKE  EQU   22          ; create: DE=FCB
BF_SETDMA EQU   26          ; set DMA: DE=addr
BF_USRNUM EQU   32          ; get/set user: E=num
BF_CURDSK EQU   25          ; get current disk

;--- FCB field offsets --------------------------------
FCB_DR  EQU     0           ; drive (0=default, 1=A, etc.)
FCB_F1  EQU     1           ; filename (8 bytes)
FCB_T1  EQU     9           ; extension (3 bytes)
FCB_EX  EQU     12          ; extent number
FCB_RC  EQU     15          ; record count
FCB_CR  EQU     32          ; current record

;--- ASCII control codes ------------------------------
NUL     EQU     00H
BEL     EQU     07H         ; bell
BS      EQU     08H         ; backspace
TAB     EQU     09H         ; horizontal tab
LF      EQU     0AH         ; line feed
CR      EQU     0DH         ; carriage return
ESC     EQU     1BH         ; escape
DEL     EQU     7FH         ; delete character
CPMEOF  EQU     1AH         ; CP/M EOF marker (Ctrl-Z)
CTRLK   EQU     0BH         ; Ctrl-K (prefix key)
CTRLQ   EQU     11H         ; Ctrl-Q (prefix key)

;--- Screen layout ------------------------------------
SCRROWS EQU     24          ; terminal row count
SCRCOLS EQU     80          ; terminal column count
EDITROW EQU     20          ; hex data rows (rows 3-22)
EDITFR  EQU     3           ; first edit row (1-based)
INFOROW EQU     1           ; info bar row
HDRROW  EQU     2           ; column header row
SEPRROW EQU     23          ; separator (===) row
STATROW EQU     24          ; status/message row

;--- Hex display layout -------------------------------
BYTESROW EQU    16          ; bytes per display row
BYTESPG EQU     320         ; bytes per page (EDITROW*BYTESROW)
HEXFCOL EQU     7           ; first hex column (1-based)
ASCFCOL EQU     58          ; first ASCII column (1-based)
GRPSEP  EQU     31          ; column of group separator space
ADDRWID EQU     6           ; width of "XXXX: " address field

;--- Hex input modes ----------------------------------
MODE_HEX EQU   0           ; editing in hex field
MODE_ASC EQU   1           ; editing in ASCII field
MODE_OVR EQU   0           ; overwrite mode
MODE_INS EQU   1           ; insert mode

;--- SGR attribute byte values ------------------------
ATTR_NRM EQU    00H         ; normal
ATTR_BLD EQU    01H         ; bold
ATTR_DIM EQU    02H         ; dim
ATTR_REV EQU    07H         ; reverse video
ATTR_CYN EQU    36H         ; cyan foreground
ATTR_GRN EQU    32H         ; green foreground
ATTR_YEL EQU    33H         ; yellow foreground
ATTR_MAG EQU    35H         ; magenta foreground
ATTR_RED EQU    31H         ; red foreground
ATTR_BLU EQU    34H         ; blue foreground

;--- Buffer descriptor field offsets ------------------
BD_BSTAR EQU    0           ; 2: buffer base address
BD_BSIZE EQU    2           ; 2: capacity in bytes
BD_GAPBG EQU    4           ; 2: gap start offset
BD_GAPEN EQU    6           ; 2: gap end offset
BD_TXEND EQU    8           ; 2: logical data length
BD_TOPOFF EQU   10          ; 2: top visible byte offset
BD_CSOFF EQU    12          ; 2: cursor byte offset
BD_MRKBG EQU    14          ; 2: block mark start (FFFF=unset)
BD_MRKEN EQU    16          ; 2: block mark end (FFFF=unset)
BD_MODIF EQU    18          ; 1: modified flag
BD_FILEFMT EQU  19          ; 1: file format (0=bin, 1=ihex)
BD_FNAME EQU    20          ; 12: drive + filename + ext
BD_SIZE  EQU    32          ; total descriptor size

;--- File format codes --------------------------------
FMT_BIN EQU     0           ; raw binary
FMT_IHEX EQU    1           ; Intel HEX

;--- Key types (from GETKEY) --------------------------
KT_NONE EQU     0           ; no key
KT_ACT  EQU     1           ; action code
KT_CHAR EQU     2           ; printable character

;--- Action codes -------------------------------------
ACT_NONE  EQU   0
ACT_CURUP EQU   1           ; cursor up (16 bytes)
ACT_CURDN EQU   2           ; cursor down (16 bytes)
ACT_CURLT EQU   3           ; cursor left (1 byte)
ACT_CURRT EQU   4           ; cursor right (1 byte)
ACT_PGUP  EQU   5           ; page up (320 bytes)
ACT_PGDN  EQU   6           ; page down (320 bytes)
ACT_HOME  EQU   7           ; start of row
ACT_END   EQU   8           ; end of row
ACT_FTOP  EQU   9           ; top of file
ACT_FEND  EQU   10          ; end of file
ACT_DELLF EQU   11          ; delete left (backspace)
ACT_DELRT EQU   12          ; delete right
ACT_TOGIN EQU   13          ; toggle ins/ovr
ACT_TOGMD EQU   14          ; toggle hex/ascii mode
ACT_FNDNX EQU   15          ; find next
ACT_FSAVE EQU   16          ; save file
ACT_FEXIT EQU   17          ; exit
ACT_BLKMK EQU   18          ; block mark
ACT_BLKCP EQU   19          ; block copy
ACT_BLKDL EQU   20          ; block delete
ACT_BLKPS EQU   21          ; block paste
ACT_MENU  EQU   22          ; open ESC menu
ACT_DELRW EQU   23          ; delete row (16 bytes)
ACT_MAX   EQU   23          ; highest action code

;--- Miscellaneous ------------------------------------
MINMEM  EQU     9*1024      ; minimum TPA (9 KB)
CLIPMAX EQU     2048        ; clipboard buffer size
SRCHMAX EQU     64          ; max search pattern length
RECSIZ  EQU     128         ; CP/M record size
MAXADDR EQU     0FFFFH      ; max displayable address


        PUBLIC  GETKEY          ; read next key
        PUBLIC  KBDTBL          ; ctrl-code dispatch table
        PUBLIC  CSITBL          ; CSI sequence table
        PUBLIC  SS3TBL          ; SS3 sequence table
        PUBLIC  CTKTBL          ; Ctrl-K prefix table
        PUBLIC  CTQTBL          ; Ctrl-Q prefix table

; Key state machine states
KST_IDL EQU     0               ; idle, no prefix
KST_ESC EQU     1               ; received ESC
KST_CSI EQU     2               ; received ESC [
KST_SS3 EQU     3               ; received ESC O
KST_CSP EQU     4               ; CSI with param digits
KST_CTK EQU     5               ; Ctrl-K prefix active
KST_CTQ EQU     6               ; Ctrl-Q prefix active

; ESC timeout loop count (~1ms at 2MHz)
ESCTMO  EQU     500

;=============================================================
; GETKEY - Read next key, return decoded action or char.
; Entry:  (none)
; Exit:   B = KT_NONE (no key), KT_ACT, or KT_CHAR
;         C = action code or character
;         All other regs clobbered
; Note:   Blocks until a key is available.
;=============================================================

        CSEG

GETKEY:
        ; Poll until a character is available (blocking)
GKPOLL: MVI     E,0FFH          ; RAWIO: request input
        MVI     C,BF_RAWIO
        CALL    BDOS
        ORA     A               ; 0 = no char
        JZ      GKPOLL

        ; Save character, then check key state
        MOV     D,A             ; D = received byte
        LDA     KEYSTATE
        ORA     A
        JNZ     GKSTATE         ; in escape sequence

        ; Idle state: restore saved character and classify
        MOV     A,D             ; restore received byte

GKIDLE:
        ; A = received byte
        CPI     ESC             ; ESC starts a sequence
        JZ      GKESC
        CPI     CTRLK           ; Ctrl-K prefix
        JZ      GKCTLK
        CPI     CTRLQ           ; Ctrl-Q prefix
        JZ      GKCTLQ
        CPI     ' '             ; < space = control code
        JC      GKCTRL
        CPI     DEL             ; DEL key?
        JZ      GKDEL
        JNC     GKHIGH          ; > DEL (80h+): high-byte key
        ; 0x20-0x7E: printable ASCII character
        MOV     C,A
        MVI     B,KT_CHAR
        RET

GKCTRL: ; Control character 00-1F: look up in KBDTBL
        MOV     L,A
        MVI     H,0
        LXI     D,KBDTBL
        DAD     D               ; HL = &KBDTBL[A]
        MOV     C,M             ; C = action code
        MVI     B,KT_ACT
        MOV     A,C
        ORA     A
        RNZ                     ; return action
        MVI     B,KT_NONE       ; no action mapped
        RET

GKDEL:  MVI     C,ACT_DELRT     ; DEL = delete right
        MVI     B,KT_ACT
        RET

GKHIGH: ; High-byte key (80h-FFh): look up in HKYTBL
        MOV     D,A             ; D = byte to find
        LXI     H,HKYTBL
        JMP     TBLSRCH         ; search (byte,action) table

GKESC:  MVI     A,KST_ESC       ; enter ESC state
        STA     KEYSTATE
        ; Try to read next byte with timeout
        LXI     B,ESCTMO
ESCTL:  PUSH    B               ; save timeout counter
        MVI     E,0FFH
        MVI     C,BF_RAWIO
        CALL    BDOS
        POP     B               ; restore timeout counter
        ORA     A
        JNZ     GKESC2          ; got a byte
        DCX     B
        MOV     A,B
        ORA     C
        JNZ     ESCTL
        ; Timeout: ESC alone = open menu
        XRA     A
        STA     KEYSTATE        ; back to idle
        MVI     C,ACT_MENU
        MVI     B,KT_ACT
        RET

GKESC2: ; A = byte after ESC
        MOV     D,A             ; save byte
        XRA     A
        STA     KEYSTATE        ; reset state
        MOV     A,D             ; restore byte
        CPI     '['             ; ESC [ = CSI
        JZ      GKCSI
        CPI     'O'             ; ESC O = SS3
        JZ      GKSS3
        CPI     'Z'             ; ESC Z = identify
        JZ      GKIDZP
        ; Unknown ESC sequence - ignore
        MVI     B,KT_NONE
        RET

GKCSI:
        ; Read CSI parameter and final byte
        LXI     B,ESCTMO
        XRA     A
        STA     CSIPARM         ; clear parameter
GKCSILP:
        PUSH    B               ; save timeout counter
        MVI     E,0FFH
        MVI     C,BF_RAWIO
        CALL    BDOS
        POP     B               ; restore timeout counter
        ORA     A
        JNZ     GKCSIB
        DCX     B
        MOV     A,B
        ORA     C
        JNZ     GKCSILP
        MVI     B,KT_NONE       ; timeout
        RET

GKCSIB: ; A = byte of CSI sequence
        CPI     '0'
        JC      GKCFIN          ; < '0' = final
        CPI     '9'+1
        JNC     GKCFIN          ; > '9' = final
        ; Digit: accumulate CSIPARM = CSIPARM * 10 + (A - '0')
        SUI     '0'             ; A = digit value (0-9)
        MOV     E,A             ; E = digit value
        LDA     CSIPARM         ; A = current param
        ADD     A               ; *2
        MOV     D,A             ; D = param*2
        ADD     A               ; *4
        ADD     A               ; *8
        ADD     D               ; +param*2 = *10
        ADD     E               ; + digit value
        STA     CSIPARM
        JMP     GKCSILP

GKCFIN: ; A = CSI final byte
        MOV     D,A             ; save final byte
        LDA     CSIPARM
        MOV     E,A             ; E = parameter
        MOV     A,D             ; restore final
        ; Look up in CSI table
        LXI     H,CSITBL
GCSILK: MOV     A,M
        ORA     A
        JZ      GCSINF          ; end of table
        CMP     D               ; match final byte?
        JNZ     GCSINX
        INX     H
        MOV     A,M             ; get parameter
        CMP     E               ; match parameter?
        JNZ     GCSKP2          ; param mismatch: skip 2
        INX     H
        MOV     C,M             ; C = action code
        MVI     B,KT_ACT
        RET
GCSKP2: INX     H               ; skip param
        INX     H               ; skip action
        JMP     GCSILK
GCSINX: INX     H               ; skip final
        INX     H               ; skip param
        INX     H               ; skip action
        JMP     GCSILK
GCSINF: MVI     B,KT_NONE
        RET

GKSS3:
        ; Read SS3 final byte
        LXI     B,ESCTMO
GKSS3L: PUSH    B               ; save timeout counter
        MVI     E,0FFH
        MVI     C,BF_RAWIO
        CALL    BDOS
        POP     B               ; restore timeout counter
        ORA     A
        JNZ     GKSS3B
        DCX     B
        MOV     A,B
        ORA     C
        JNZ     GKSS3L
        MVI     B,KT_NONE
        RET

GKSS3B: ; A = SS3 final byte
        MOV     D,A             ; D = byte to find
        LXI     H,SS3TBL
GS3LK:  MOV     A,M             ; A = table char
        ORA     A               ; end of table?
        JZ      GS3NF
        CMP     D               ; match final byte?
        JZ      GS3FND
        INX     H               ; skip char
        INX     H               ; skip action
        JMP     GS3LK
GS3FND: INX     H
        MOV     C,M             ; C = action code
        MVI     B,KT_ACT
        RET
GS3NF:  MVI     B,KT_NONE
        RET

GKIDZP: ; ESC Z identify - ignore, return no action
        MVI     B,KT_NONE
        RET

GKCTLK: ; Ctrl-K prefix: read next byte, look up
        MVI     A,KST_CTK
        STA     KEYSTATE
        CALL    GKWAIT          ; blocking read
        XRA     A
        STA     KEYSTATE
        LXI     H,CTKTBL
        JMP     TBLSRCH         ; search (char,action) list

GKCTLQ: ; Ctrl-Q prefix: read next byte, look up
        MVI     A,KST_CTQ
        STA     KEYSTATE
        CALL    GKWAIT          ; blocking read
        XRA     A
        STA     KEYSTATE
        LXI     H,CTQTBL
        JMP     TBLSRCH

GKSTATE: ; Currently in a prefix state - should not
         ; reach here from polling loop. Reset.
        XRA     A
        STA     KEYSTATE
        MVI     B,KT_NONE
        RET

;------------------------------------------------------------
; GKWAIT - Blocking read of one byte from console.
; Exit:   A = byte; D = byte (saved)
;------------------------------------------------------------
GKWAIT:
        MVI     E,0FFH          ; raw console input
        MVI     C,BF_RAWIO
        CALL    BDOS
        ORA     A
        JZ      GKWAIT          ; no char yet, poll
        MOV     D,A
        RET

;------------------------------------------------------------
; TBLSRCH - Search (char, action) table for char in D.
; Entry:  HL = table start (ends with 0,0 sentinel)
;         D  = character to find
; Exit:   B=KT_ACT, C=action if found; B=KT_NONE if not
;------------------------------------------------------------
TBLSRCH:
        MOV     A,M
        ORA     A
        JZ      TBLNF           ; end of table
        CMP     D
        JZ      TBLFND
        INX     H
        INX     H               ; skip action byte
        JMP     TBLSRCH
TBLFND: INX     H
        MOV     C,M             ; C = action code
        MVI     B,KT_ACT
        RET
TBLNF:  MVI     B,KT_NONE
        RET

;=============================================================
; Key dispatch tables
;=============================================================

; KBDTBL - Action for ctrl codes 0-31 (index = ctrl code)
; 0 = no action for that code
KBDTBL:
        DB      0               ;  0 NUL - unused
        DB      0               ;  1 ^A  - unused
        DB      0               ;  2 ^B  - unused
        DB      ACT_PGDN        ;  3 ^C  - page down
        DB      ACT_CURRT       ;  4 ^D  - cursor right
        DB      ACT_CURUP       ;  5 ^E  - cursor up
        DB      0               ;  6 ^F  - unused
        DB      ACT_DELRT       ;  7 ^G  - delete right
        DB      ACT_DELLF       ;  8 ^H  - backspace
        DB      ACT_TOGMD       ;  9 ^I  - toggle hex/ascii
        DB      0               ; 10 ^J  - unused
        DB      0               ; 11 ^K  - prefix (block)
        DB      ACT_FNDNX       ; 12 ^L  - find next
        DB      0               ; 13 ^M  - unused (Enter)
        DB      0               ; 14 ^N  - unused
        DB      ACT_BLKCP       ; 15 ^O  - block copy
        DB      0               ; 16 ^P  - unused
        DB      0               ; 17 ^Q  - prefix (quick)
        DB      ACT_PGUP        ; 18 ^R  - page up
        DB      ACT_CURLT       ; 19 ^S  - cursor left
        DB      0               ; 20 ^T  - unused
        DB      0               ; 21 ^U  - unused
        DB      ACT_TOGIN       ; 22 ^V  - toggle ins/ovr
        DB      0               ; 23 ^W  - unused
        DB      ACT_CURDN       ; 24 ^X  - cursor down
        DB      ACT_DELRW       ; 25 ^Y  - delete row
        DB      0               ; 26 ^Z  - unused
        DB      ACT_MENU        ; 27 ESC - menu
        DB      0               ; 28 FS  - unused
        DB      0               ; 29 GS  - unused
        DB      0               ; 30 RS  - unused
        DB      0               ; 31 US  - unused

; CSI table: (final_byte, parameter, action) triples
; Ends with 0,0,0
CSITBL:
        DB      'A',0,ACT_CURUP     ; ESC[A up arrow
        DB      'B',0,ACT_CURDN     ; ESC[B down arrow
        DB      'C',0,ACT_CURRT     ; ESC[C right arrow
        DB      'D',0,ACT_CURLT     ; ESC[D left arrow
        DB      'H',0,ACT_HOME      ; ESC[H home (xterm)
        DB      'F',0,ACT_END       ; ESC[F end (xterm)
        DB      '~',1,ACT_HOME      ; ESC[1~ home VT220
        DB      '~',2,ACT_TOGIN     ; ESC[2~ insert
        DB      '~',3,ACT_DELRT     ; ESC[3~ delete
        DB      '~',4,ACT_END       ; ESC[4~ end VT220
        DB      '~',5,ACT_PGUP      ; ESC[5~ page up
        DB      '~',6,ACT_PGDN      ; ESC[6~ page down
        DB      0,0,0               ; end of table

; SS3 table: (final_byte, action) pairs
; Ends with 0,0
SS3TBL:
        DB      'A',ACT_CURUP       ; ESC OA - up arrow
        DB      'B',ACT_CURDN       ; ESC OB - down arrow
        DB      'C',ACT_CURRT       ; ESC OC - right arrow
        DB      'D',ACT_CURLT       ; ESC OD - left arrow
        DB      'P',ACT_FNDNX       ; ESC OP - F1 find next
        DB      'Q',ACT_FSAVE       ; ESC OQ - F2 save
        DB      'R',ACT_BLKMK       ; ESC OR - F3 block mark
        DB      'S',ACT_MENU        ; ESC OS - F4 menu
        DB      0,0                 ; end of table

; Ctrl-K prefix table: (char, action) pairs
; Ends with 0,0
CTKTBL:
        DB      'S',ACT_FSAVE       ; ^KS save
        DB      's',ACT_FSAVE
        DB      'B',ACT_BLKMK       ; ^KB block mark
        DB      'b',ACT_BLKMK
        DB      'C',ACT_BLKCP       ; ^KC block copy
        DB      'c',ACT_BLKCP
        DB      'D',ACT_BLKDL       ; ^KD block delete
        DB      'd',ACT_BLKDL
        DB      'P',ACT_BLKPS       ; ^KP paste
        DB      'p',ACT_BLKPS
        DB      'X',ACT_FEXIT       ; ^KX exit
        DB      'x',ACT_FEXIT
        DB      'Q',ACT_FEXIT       ; ^KQ quit
        DB      'q',ACT_FEXIT
        DB      0,0                 ; end

; Ctrl-Q prefix table: (char, action) pairs
CTQTBL:
        DB      'F',ACT_FNDNX       ; ^QF find
        DB      'f',ACT_FNDNX
        DB      'S',ACT_HOME        ; ^QS home (start of row)
        DB      's',ACT_HOME
        DB      'D',ACT_END         ; ^QD end (end of row)
        DB      'd',ACT_END
        DB      'R',ACT_FTOP        ; ^QR file top
        DB      'r',ACT_FTOP
        DB      'C',ACT_FEND        ; ^QC file end
        DB      'c',ACT_FEND
        DB      0,0                 ; end

; High-byte key table: (byte, action) pairs
; For terminals that send single bytes >= 80h for special keys
; Ends with 0,0
HKYTBL:
        DB      0EDH,ACT_CURUP     ; EDh = up arrow
        DB      0ECH,ACT_CURDN     ; ECh = down arrow
        DB      0EBH,ACT_CURLT     ; EBh = left arrow
        DB      0EAH,ACT_CURRT     ; EAh = right arrow
        DB      0F3H,ACT_TOGIN     ; F3h = insert
        DB      0F2H,ACT_DELRT     ; F2h = delete
        DB      0F1H,ACT_HOME      ; F1h = home
        DB      0F0H,ACT_END       ; F0h = end
        DB      0EFH,ACT_PGUP      ; EFh = page up
        DB      0EEH,ACT_PGDN      ; EEh = page down
        DB      0,0                 ; end of table

;=============================================================
; DATA SEGMENT
;=============================================================
        DSEG

KEYSTATE: DB    0               ; current decode state
CSIPARM:  DB    0               ; accumulated CSI param

        END
