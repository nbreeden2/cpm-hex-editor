;============================================================
; FILE:    HEXBLK.MAC
; PROJECT: HEDIT - Hex Editor for CP/M 2.2
; VERSION: 1.0
; DATE:    1984-01-01
; AUTHOR:  Claude Code and RetroTechReboot
;------------------------------------------------------------
; DESCRIPTION:
;   Block mark, copy, delete, and paste operations.
;
;   The block is defined by two logical offsets stored in
;   the buffer descriptor fields BD_MRKBG and BD_MRKEN.
;   Both are set to 0FFFFh when no block is marked.
;
;   BLMARK  - Toggle block mark: if no mark, set start =
;             current cursor offset; if start is set but end
;             is not, set end = current cursor offset
;             (end >= start enforced); if both set, clear.
;   BLCOPY  - Copy marked block to clipboard (CLPBUF).
;   BLDEL   - Delete marked block from buffer.
;   BLPASTE - Insert clipboard contents at cursor.
;------------------------------------------------------------
; REVISION HISTORY:
;   1.0  1984-01-01  Initial release
;============================================================

;============================================================
; FILE:    HEDIT.INC
; PROJECT: HEDIT - Hex Editor for CP/M 2.2
; VERSION: 1.0
; DATE:    1984-01-01
; AUTHOR:  Claude Code and RetroTechReboot
;------------------------------------------------------------
; DESCRIPTION:
;   Shared equates for all HEDIT modules.
;   INCLUDE this as the first statement of every .MAC file.
;------------------------------------------------------------

;--- CP/M system addresses ----------------------------
BDOS    EQU     0005H       ; BDOS call entry
WBOOT   EQU     0000H       ; warm boot / exit
DFTFCB  EQU     005CH       ; default FCB (arg 1)
CMDTAIL EQU     0080H       ; command tail buffer

;--- BDOS function numbers ----------------------------
BF_CONIN  EQU   1           ; console input (wait)
BF_CONOUT EQU   2           ; console output: E=char
BF_RAWIO  EQU   6           ; direct I/O: E=FFH->in
BF_PRTSTR EQU   9           ; print $-string: DE=addr
BF_RDLINE EQU   10          ; buffered line input
BF_CONST  EQU   11          ; console status
BF_FOPEN  EQU   15          ; open file: DE=FCB
BF_FCLOSE EQU   16          ; close file: DE=FCB
BF_FDEL   EQU   19          ; delete: DE=FCB
BF_FREAD  EQU   20          ; seq read: DE=FCB
BF_FWRITE EQU   21          ; seq write: DE=FCB
BF_FMAKE  EQU   22          ; create: DE=FCB
BF_SETDMA EQU   26          ; set DMA: DE=addr
BF_USRNUM EQU   32          ; get/set user: E=num
BF_CURDSK EQU   25          ; get current disk

;--- FCB field offsets --------------------------------
FCB_DR  EQU     0           ; drive (0=default, 1=A, etc.)
FCB_F1  EQU     1           ; filename (8 bytes)
FCB_T1  EQU     9           ; extension (3 bytes)
FCB_EX  EQU     12          ; extent number
FCB_RC  EQU     15          ; record count
FCB_CR  EQU     32          ; current record

;--- ASCII control codes ------------------------------
NUL     EQU     00H
BEL     EQU     07H         ; bell
BS      EQU     08H         ; backspace
TAB     EQU     09H         ; horizontal tab
LF      EQU     0AH         ; line feed
CR      EQU     0DH         ; carriage return
ESC     EQU     1BH         ; escape
DEL     EQU     7FH         ; delete character
CPMEOF  EQU     1AH         ; CP/M EOF marker (Ctrl-Z)
CTRLK   EQU     0BH         ; Ctrl-K (prefix key)
CTRLQ   EQU     11H         ; Ctrl-Q (prefix key)

;--- Screen layout ------------------------------------
SCRROWS EQU     24          ; terminal row count
SCRCOLS EQU     80          ; terminal column count
EDITROW EQU     20          ; hex data rows (rows 3-22)
EDITFR  EQU     3           ; first edit row (1-based)
INFOROW EQU     1           ; info bar row
HDRROW  EQU     2           ; column header row
SEPRROW EQU     23          ; separator (===) row
STATROW EQU     24          ; status/message row

;--- Hex display layout -------------------------------
BYTESROW EQU    16          ; bytes per display row
BYTESPG EQU     320         ; bytes per page (EDITROW*BYTESROW)
HEXFCOL EQU     7           ; first hex column (1-based)
ASCFCOL EQU     58          ; first ASCII column (1-based)
GRPSEP  EQU     31          ; column of group separator space
ADDRWID EQU     6           ; width of "XXXX: " address field

;--- Hex input modes ----------------------------------
MODE_HEX EQU   0           ; editing in hex field
MODE_ASC EQU   1           ; editing in ASCII field
MODE_OVR EQU   0           ; overwrite mode
MODE_INS EQU   1           ; insert mode

;--- SGR attribute byte values ------------------------
ATTR_NRM EQU    00H         ; normal
ATTR_BLD EQU    01H         ; bold
ATTR_DIM EQU    02H         ; dim
ATTR_REV EQU    07H         ; reverse video
ATTR_CYN EQU    36H         ; cyan foreground
ATTR_GRN EQU    32H         ; green foreground
ATTR_YEL EQU    33H         ; yellow foreground
ATTR_MAG EQU    35H         ; magenta foreground
ATTR_RED EQU    31H         ; red foreground
ATTR_BLU EQU    34H         ; blue foreground

;--- Buffer descriptor field offsets ------------------
BD_BSTAR EQU    0           ; 2: buffer base address
BD_BSIZE EQU    2           ; 2: capacity in bytes
BD_GAPBG EQU    4           ; 2: gap start offset
BD_GAPEN EQU    6           ; 2: gap end offset
BD_TXEND EQU    8           ; 2: logical data length
BD_TOPOFF EQU   10          ; 2: top visible byte offset
BD_CSOFF EQU    12          ; 2: cursor byte offset
BD_MRKBG EQU    14          ; 2: block mark start (FFFF=unset)
BD_MRKEN EQU    16          ; 2: block mark end (FFFF=unset)
BD_MODIF EQU    18          ; 1: modified flag
BD_FILEFMT EQU  19          ; 1: file format (0=bin, 1=ihex)
BD_FNAME EQU    20          ; 12: drive + filename + ext
BD_SIZE  EQU    32          ; total descriptor size

;--- File format codes --------------------------------
FMT_BIN EQU     0           ; raw binary
FMT_IHEX EQU    1           ; Intel HEX

;--- Key types (from GETKEY) --------------------------
KT_NONE EQU     0           ; no key
KT_ACT  EQU     1           ; action code
KT_CHAR EQU     2           ; printable character

;--- Action codes -------------------------------------
ACT_NONE  EQU   0
ACT_CURUP EQU   1           ; cursor up (16 bytes)
ACT_CURDN EQU   2           ; cursor down (16 bytes)
ACT_CURLT EQU   3           ; cursor left (1 byte)
ACT_CURRT EQU   4           ; cursor right (1 byte)
ACT_PGUP  EQU   5           ; page up (320 bytes)
ACT_PGDN  EQU   6           ; page down (320 bytes)
ACT_HOME  EQU   7           ; start of row
ACT_END   EQU   8           ; end of row
ACT_FTOP  EQU   9           ; top of file
ACT_FEND  EQU   10          ; end of file
ACT_DELLF EQU   11          ; delete left (backspace)
ACT_DELRT EQU   12          ; delete right
ACT_TOGIN EQU   13          ; toggle ins/ovr
ACT_TOGMD EQU   14          ; toggle hex/ascii mode
ACT_FNDNX EQU   15          ; find next
ACT_FSAVE EQU   16          ; save file
ACT_FEXIT EQU   17          ; exit
ACT_BLKMK EQU   18          ; block mark
ACT_BLKCP EQU   19          ; block copy
ACT_BLKDL EQU   20          ; block delete
ACT_BLKPS EQU   21          ; block paste
ACT_MENU  EQU   22          ; open ESC menu
ACT_DELRW EQU   23          ; delete row (16 bytes)
ACT_MAX   EQU   23          ; highest action code

;--- Miscellaneous ------------------------------------
MINMEM  EQU     9*1024      ; minimum TPA (9 KB)
CLIPMAX EQU     2048        ; clipboard buffer size
SRCHMAX EQU     64          ; max search pattern length
RECSIZ  EQU     128         ; CP/M record size
MAXADDR EQU     0FFFFH      ; max displayable address


;--- Imports ----------------------------------------------
        EXTRN   CURBDP          ; current buffer descriptor
        EXTRN   DIRTY           ; screen redraw flag
        EXTRN   GBINSRT         ; insert byte at cursor
        EXTRN   GBDLFT          ; delete byte left of cursor
        EXTRN   GBDELRT         ; delete byte right of cursor
        EXTRN   GBMVTO          ; move cursor to offset HL
        EXTRN   GBCSOFF         ; get cursor offset -> HL
        EXTRN   GBLOGRD         ; read byte at logical offset HL
        EXTRN   GBTXEND         ; get text end -> HL
        EXTRN   STATMSG         ; status bar message

;--- Exports ----------------------------------------------
        PUBLIC  BLMARK          ; toggle block mark
        PUBLIC  BLCOPY          ; copy block to clipboard
        PUBLIC  BLDEL           ; delete block
        PUBLIC  BLPASTE         ; paste clipboard at cursor

;=============================================================
; BLMARK - Toggle block mark at current cursor offset.
; State machine (stored in BD_MRKBG / BD_MRKEN):
;   Both = FFFFh     -> set MRKBG = cursor, MRKEN = FFFFh
;   MRKBG set, MRKEN = FFFFh -> set MRKEN = cursor
;                                (swap if MRKEN < MRKBG)
;   Both set         -> clear both to FFFFh
;=============================================================
        CSEG

BLMARK:
        ; Read MRKBG
        CALL    BLRDMB          ; HL = MRKBG
        ; Check if MRKBG = 0FFFFh (no mark)
        MOV     A,H
        CPI     0FFH
        JNZ     BLMST2          ; MRKBG already set
        MOV     A,L
        CPI     0FFH
        JNZ     BLMST2

        ; MRKBG = FFFFh -> set MRKBG = cursor offset
        CALL    BLCUROF         ; HL = cursor offset
        CALL    BLWRMB          ; MRKBG = HL
        ; Set MRKEN = FFFFh
        LXI     H,0FFFFH
        CALL    BLWRME
        LXI     D,BM1MSG
        JMP     STATMSG

BLMST2:
        ; MRKBG is set; check MRKEN
        CALL    BLRDME          ; HL = MRKEN
        MOV     A,H
        CPI     0FFH
        JNZ     BLMCLR          ; both set -> clear
        MOV     A,L
        CPI     0FFH
        JNZ     BLMCLR

        ; MRKEN = FFFFh -> set MRKEN = cursor
        CALL    BLCUROF         ; HL = cursor
        XCHG                    ; DE = cursor
        PUSH    D               ; save cursor
        CALL    BLRDMB          ; HL = MRKBG
        POP     D               ; DE = cursor restored
        ; If cursor < MRKBG: swap them
        MOV     A,D
        CMP     H
        JC      BLMSWP          ; cursor.H < MRKBG.H
        JNZ     BLMSET          ; cursor.H > MRKBG.H
        MOV     A,E
        CMP     L
        JNC     BLMSET          ; cursor >= MRKBG: ok

BLMSWP: ; cursor < MRKBG: swap so MRKBG <= MRKEN
        ; DE = cursor (new MRKBG), HL = old MRKBG (new MRKEN)
        PUSH    H               ; save old MRKBG
        XCHG                    ; HL = cursor
        CALL    BLWRMB          ; MRKBG = cursor
        POP     H               ; HL = old MRKBG
        CALL    BLWRME          ; MRKEN = old MRKBG
        LXI     D,BM2MSG
        JMP     STATMSG

BLMSET: ; MRKEN = cursor (DE)
        XCHG
        CALL    BLWRME          ; MRKEN = HL (cursor)
        LXI     D,BM2MSG
        JMP     STATMSG

BLMCLR: ; Clear both marks
        LXI     H,0FFFFH
        CALL    BLWRMB
        LXI     H,0FFFFH
        CALL    BLWRME
        LXI     D,BMCMSG
        JMP     STATMSG

;=============================================================
; BLCOPY - Copy marked block to clipboard (CLPBUF).
; Does nothing if block not fully marked.
; Reads MRKEN-MRKBG bytes from MRKBG via GBLOGRD.
;=============================================================
BLCOPY:
        CALL    BLCHKMK         ; check block valid; Z = invalid
        RZ

        ; Init walk position and clipboard pointer
        LHLD    BLKBG
        SHLD    BLKPOS          ; walk position = mark start
        LXI     H,0
        SHLD    CLPCNT          ; byte count = 0
        LXI     H,CLPBUF
        SHLD    CLPPTR          ; clip write pointer

BCCPLP:
        ; Check BLKPOS < BLKEN
        LHLD    BLKEN
        XCHG                    ; DE = BLKEN
        LHLD    BLKPOS          ; HL = BLKPOS
        MOV     A,H
        CMP     D
        JC      BCGBYT          ; BLKPOS.H < BLKEN.H: continue
        JNZ     BCDON           ; BLKPOS.H > BLKEN.H: done
        MOV     A,L
        CMP     E
        JNC     BCDON           ; BLKPOS >= BLKEN: done

BCGBYT:
        ; Read byte at BLKPOS from gap buffer
        LHLD    BLKPOS
        CALL    GBLOGRD         ; A = byte (regs clobbered)

        ; Store byte to clipboard via saved pointer
        LHLD    CLPPTR
        MOV     M,A
        INX     H
        SHLD    CLPPTR          ; advance write pointer

        ; Increment count and check CLIPMAX
        LHLD    CLPCNT
        INX     H
        SHLD    CLPCNT
        MOV     A,H
        CPI     HIGH(CLIPMAX)
        JC      BCNFLL          ; count.H < CLIPMAX.H: not full
        JNZ     BCDON           ; count.H > CLIPMAX.H: full
        MOV     A,L
        CPI     LOW(CLIPMAX)
        JNC     BCDON           ; count >= CLIPMAX: stop

BCNFLL:
        ; Advance walk position
        LHLD    BLKPOS
        INX     H
        SHLD    BLKPOS
        JMP     BCCPLP

BCDON:
        ; Store clip length
        LHLD    CLPCNT
        SHLD    CLPLEN

        LXI     D,BCPMSG
        JMP     STATMSG

;=============================================================
; BLDEL - Delete marked block from buffer.
; Moves cursor to MRKBG, then repeatedly calls GBDELRT.
;=============================================================
BLDEL:
        CALL    BLCHKMK
        RZ                      ; no block

        ; Navigate to BLKBG
        LHLD    BLKBG
        CALL    GBMVTO          ; move cursor to mark start

        ; Delete BLKEN-BLKBG bytes
        ; Compute count = BLKEN - BLKBG
        LHLD    BLKEN
        XCHG                    ; DE = BLKEN
        LHLD    BLKBG           ; HL = BLKBG
        MOV     A,E
        SUB     L
        MOV     L,A
        MOV     A,D
        SBB     H
        MOV     H,A             ; HL = count
        SHLD    BDDCNT          ; save count to memory

BDDELP:
        LHLD    BDDCNT
        MOV     A,H
        ORA     L
        JZ      BDDON
        CALL    GBDELRT         ; delete one byte right (clobbers all)
        LHLD    BDDCNT
        DCX     H
        SHLD    BDDCNT
        JMP     BDDELP

BDDON:
        ; Clear block marks
        LXI     H,0FFFFH
        CALL    BLWRMB
        LXI     H,0FFFFH
        CALL    BLWRME

        MVI     A,1
        STA     DIRTY
        LXI     D,BDLMSG
        JMP     STATMSG

;=============================================================
; BLPASTE - Insert clipboard contents at current cursor.
; For each byte in CLPBUF[0..CLPLEN-1]: call GBINSRT.
;=============================================================
BLPASTE:
        LHLD    CLPLEN
        MOV     A,H
        ORA     L
        JZ      BPNONE          ; nothing in clipboard

        SHLD    BPCNT           ; count = CLPLEN
        LXI     H,CLPBUF
        SHLD    CLPPTR          ; read pointer = CLPBUF

BPLOOP:
        LHLD    BPCNT
        MOV     A,H
        ORA     L
        JZ      BPDONE

        LHLD    CLPPTR
        MOV     A,M             ; read byte from clipboard
        INX     H
        SHLD    CLPPTR          ; advance and save read pointer

        CALL    GBINSRT         ; insert at cursor (clobbers all regs)

        LHLD    BPCNT
        DCX     H
        SHLD    BPCNT           ; decrement count
        JMP     BPLOOP

BPDONE:
        MVI     A,1
        STA     DIRTY
        LXI     D,BPSMSG
        JMP     STATMSG

BPNONE:
        LXI     D,BPEMSG
        JMP     STATMSG

;=============================================================
; Internal helpers
;=============================================================

;------------------------------------------------------------
; BLCHKMK - Verify block is fully marked.
; Sets BLKBG and BLKEN from descriptor.
; Exit: Z = 1 if NOT valid (caller should RZ/return)
;       Z = 0 if valid
;------------------------------------------------------------
BLCHKMK:
        CALL    BLRDMB          ; HL = MRKBG
        MOV     A,H
        CPI     0FFH
        JZ      BLCKNM          ; might be FFFFh
        SHLD    BLKBG
        JMP     BLCKME

BLCKNM: MOV     A,L
        CPI     0FFH
        JZ      BLCKNV          ; FFFFh = no mark
        ; H=FFh but L!=FFh: valid offset
        LHLD    BLKBG           ; already partially set...
        CALL    BLRDMB          ; re-read
        SHLD    BLKBG

BLCKME: CALL    BLRDME          ; HL = MRKEN
        MOV     A,H
        CPI     0FFH
        JZ      BLCKE2
        SHLD    BLKEN
        JMP     BLCKGD

BLCKE2: MOV     A,L
        CPI     0FFH
        JZ      BLCKNV          ; FFFFh = no mark
        SHLD    BLKEN

BLCKGD: ; Both set; clear zero flag (valid)
        MVI     A,1
        ORA     A               ; NZ
        RET

BLCKNV:
        LXI     D,BNMMSG
        CALL    STATMSG
        XRA     A               ; Z = invalid
        RET

;------------------------------------------------------------
; BLCUROF - Return current cursor offset in HL.
;------------------------------------------------------------
BLCUROF:
        CALL    GBCSOFF         ; HL = cursor offset
        RET

;------------------------------------------------------------
; BLRDMB - Read BD_MRKBG from current descriptor into HL.
;------------------------------------------------------------
BLRDMB:
        LHLD    CURBDP
        MOV     A,L
        ADI     BD_MRKBG
        MOV     L,A
        MOV     A,H
        ACI     0
        MOV     H,A
        MOV     E,M
        INX     H
        MOV     D,M
        XCHG
        RET

;------------------------------------------------------------
; BLRDME - Read BD_MRKEN from current descriptor into HL.
;------------------------------------------------------------
BLRDME:
        LHLD    CURBDP
        MOV     A,L
        ADI     BD_MRKEN
        MOV     L,A
        MOV     A,H
        ACI     0
        MOV     H,A
        MOV     E,M
        INX     H
        MOV     D,M
        XCHG
        RET

;------------------------------------------------------------
; BLWRMB - Write HL to BD_MRKBG in current descriptor.
;------------------------------------------------------------
BLWRMB:
        PUSH    H               ; save value
        LHLD    CURBDP
        MOV     A,L
        ADI     BD_MRKBG
        MOV     L,A
        MOV     A,H
        ACI     0
        MOV     H,A
        POP     D               ; DE = value to write
        MOV     M,E
        INX     H
        MOV     M,D
        RET

;------------------------------------------------------------
; BLWRME - Write HL to BD_MRKEN in current descriptor.
;------------------------------------------------------------
BLWRME:
        PUSH    H
        LHLD    CURBDP
        MOV     A,L
        ADI     BD_MRKEN
        MOV     L,A
        MOV     A,H
        ACI     0
        MOV     H,A
        POP     D
        MOV     M,E
        INX     H
        MOV     M,D
        RET

;=============================================================
; DATA SEGMENT
;=============================================================
        DSEG

; Validated block bounds (set by BLCHKMK)
BLKBG:  DW      0
BLKEN:  DW      0

; Delete counter
BDDCNT: DW      0

; Clipboard buffer
CLPBUF: DS      CLIPMAX         ; 2048 bytes
CLPLEN: DW      0               ; clipboard length
CLPCNT: DW      0               ; temp counter during copy

; BLKPOS for BLCOPY walk
BLKPOS: DW      0
; Clipboard read/write pointer (shared by BLCOPY and BLPASTE)
CLPPTR: DW      0
; Paste counter
BPCNT:  DW      0

; Status messages
BM1MSG:  DB     'Mark start.$'
BM2MSG:  DB     'Mark end.  $'
BMCMSG:  DB     'Mark clear.$'
BNMMSG:  DB     'No block.  $'
BCPMSG:  DB     'Block copied.$'
BDLMSG:  DB     'Block deleted.$'
BPSMSG:  DB     'Pasted.$'
BPEMSG:  DB     'Clip empty.$'

        END
