; HEDIT-CR.SUB - build HEDIT-CR.COM (Cromemco 3102).
; Self-contained: rebuilds HEPATCH.COM first.
; Cromemco 3102 is always mono; COLOR is normalised to 0.
M80 =HEPATCH
L80 HEPATCH,HEPATCH/N/E
HEPATCH 0
ERA *.REL
M80 =HEDIT
M80 =HEC3102
M80 =HEC3102K
M80 =HEXGAP
M80 =HEXIO
M80 =HEXMNVT
M80 =HEXSRCH
M80 =HEXBLK
M80 =HEXKBND
M80 =HEXVIRT
M80 =HEXHELP
L80 HEDIT,HEC3102,HEC3102K,HEXGAP,HEXIO,HEXMNVT,HEXSRCH,HEXBLK,HEXKBND,HEXVIRT,HEXHELP,TEMP/N/E
ERA HEDIT-CR.COM
REN HEDIT-CR.COM=TEMP.COM
