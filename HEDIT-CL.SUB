; HEDIT-CL.SUB - build HEDIT-CL.COM (VT100/ANSI colour).
; Self-contained: rebuilds HEPATCH.COM first.
M80 =HEPATCH
L80 HEPATCH,HEPATCH/N/E
HEPATCH 1
ERA *.REL
M80 =HEDIT
M80 =HEXSCR
M80 =HEXKEY
M80 =HEXGAP
M80 =HEXIO
M80 =HEXMENU
M80 =HEXSRCH
M80 =HEXBLK
M80 =HEXKBND
M80 =HEXVIRT
M80 =HEXHELP
L80 HEDIT,HEXSCR,HEXKEY,HEXGAP,HEXIO,HEXMENU,HEXSRCH,HEXBLK,HEXKBND,HEXVIRT,HEXHELP,TEMP/N/E
ERA HEDIT-CL.COM
REN HEDIT-CL.COM=TEMP.COM
