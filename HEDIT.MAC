;============================================================
; FILE:    HEDIT.MAC
; PROJECT: HEDIT - Hex Editor for CP/M 2.2
; VERSION: 1.04
; DATE:    1984-01-01
; AUTHOR:  Claude Code and RetroTechReboot
;------------------------------------------------------------
; DESCRIPTION:
;   Root module. Contains START: entry point, TPA memory
;   detection, module initialization, main edit loop,
;   hex/ASCII character input handling, and action dispatch.
;------------------------------------------------------------
; BUILD INSTRUCTIONS:
;   Assemble each module:
;     M80 =HEDIT
;     M80 =HEXSCR
;     M80 =HEXKEY
;     M80 =HEXGAP
;     M80 =HEXIO
;     M80 =HEXMENU
;     M80 =HEXSRCH
;     M80 =HEXBLK
;     M80 =HEXKBND
;     M80 =HEXHELP
;   Link:
;     L80 HEDIT,HEXSCR,HEXKEY,HEXGAP,HEXIO,
;         HEXMENU,HEXSRCH,HEXBLK,HEXKBND,
;         HEXHELP,HEDIT/N/E
;------------------------------------------------------------
; REVISION HISTORY:
;   1.0  1984-01-01  Initial release
;============================================================

        INCLUDE HEDIT.INC

;--- Cross-module entry points ------------------------
        EXTRN   BMDATEND        ; end-of-code marker (HEXHELP)
        EXTRN   GBINIT          ; init gap buffer
        EXTRN   GBINSRT         ; insert byte at gap
        EXTRN   GBDLFT          ; delete left (backspace)
        EXTRN   GBDELRT         ; delete right
        EXTRN   GBMVLT          ; cursor left one byte
        EXTRN   GBMVRT          ; cursor right one byte
        EXTRN   GBMVTP          ; cursor to start of buffer
        EXTRN   GBMVEND         ; cursor to end of buffer
        EXTRN   GBMVTO          ; cursor to offset in DE
        EXTRN   GBRDBLK         ; read block of bytes
        EXTRN   GBTXEND         ; HL = logical data length
        EXTRN   GBCSOFF         ; HL = cursor byte offset
        EXTRN   GBGAPBG         ; HL = gap start offset
        EXTRN   GBGAPEN         ; HL = gap end offset
        EXTRN   GBTMP           ; last deleted/inserted byte
        EXTRN   KBINIT          ; key binding init
        EXTRN   GETKEY          ; read next key
        EXTRN   SCRINIT         ; screen init/clear
        EXTRN   DETSIZ          ; detect terminal rows via DSR
        EXTRN   SCRDRAW         ; full screen redraw
        EXTRN   SCREDCL         ; redraw current row only
        EXTRN   STATMSG         ; status bar message
        EXTRN   INFOBAR         ; update info bar
        EXTRN   CURPOS          ; position HW cursor
        EXTRN   OUTSTR          ; print $-string
        EXTRN   OUTCHAR         ; print single char
        EXTRN   CURGOTO         ; move cursor (B=row, C=col)
        EXTRN   ISLOAD          ; check if file loaded
        EXTRN   FIOPEN          ; load file to buffer
        EXTRN   FISAVE          ; save buffer to file
        EXTRN   FIPROMPT        ; prompt for filename
        EXTRN   FISAVFN         ; copy WRKFCB name to BD_FNAME
        EXTRN   FISMOD          ; read BD_MODIF flag
        EXTRN   MNUSHOW         ; run ESC menu
        EXTRN   SRFIND          ; find (prompt)
        EXTRN   SRFNDNX         ; find next
        EXTRN   BLMARK          ; toggle block mark
        EXTRN   BLCOPY          ; copy block
        EXTRN   BLDEL           ; delete block
        EXTRN   BLPASTE         ; paste clipboard
        EXTRN   HLPSHOW         ; show help screen

;--- Exported symbols ---------------------------------
        PUBLIC  INSMODE         ; insert/overwrite flag
        PUBLIC  DIRTY           ; screen redraw needed
        PUBLIC  DRTLINE         ; line-only redraw flag
        PUBLIC  CURBDP          ; current buf desc ptr
        PUBLIC  TPATOP          ; TPA top address
        PUBLIC  DOEXIT          ; exit handler (for HEXMENU)
        PUBLIC  EDITMODE        ; hex/ascii mode flag
        PUBLIC  NIBBLE          ; high/low nibble flag
        PUBLIC  REROWS          ; edit row count      (runtime)
        PUBLIC  RSEPR           ; separator row       (runtime)
        PUBLIC  RSTAT           ; status row          (runtime)
        PUBLIC  RBYTPG          ; bytes per page      (runtime)

;=============================================================
; CODE SEGMENT
;=============================================================
        CSEG

;------------------------------------------------------------
; START - CP/M loads .COM at 0100H and jumps here.
; Entry:  SP near TPA top; FCB at 005CH may hold filename
; Exit:   Never returns (warm boots on exit)
;------------------------------------------------------------
START:
        LXI     H,0             ; capture incoming SP
        DAD     SP
        SHLD    OLDSP           ; save for TPA calc
        LXI     SP,STKTOP       ; set our own stack

        ; TPA top = BDOS handler address (operand of JMP at 0005H)
        LHLD    0006H           ; HL = BDOS address = TPA top
        SHLD    TPATOP          ; save it

        ; Calculate available RAM: TPATOP - BMDATEND
        LXI     D,BMDATEND
        MOV     A,L
        SUB     E
        MOV     C,A
        MOV     A,H
        SBB     D
        MOV     B,A             ; BC = available bytes

        ; Check >= MINMEM (9 KB)
        LXI     H,MINMEM
        MOV     A,B
        CMP     H
        JC      MEMFAIL         ; high byte less
        JNZ     BMOK1           ; high byte greater, ok
        MOV     A,C
        CMP     L
        JC      MEMFAIL         ; equal high, low byte less
BMOK1:
        ; BC = buffer size, DE = base address (BMDATEND)

        ; Clear buffer descriptor before GBINIT fills it
        PUSH    B               ; save buffer size
        PUSH    D               ; save base address
        LXI     H,BDESC0
        MVI     B,BD_SIZE
BDCLR:  MVI     M,0
        INX     H
        DCR     B
        JNZ     BDCLR
        POP     D               ; restore base
        POP     B               ; restore size

        ; Init gap buffer (writes BD_BSTAR, BD_BSIZE, etc.)
        LXI     H,BDESC0        ; HL = descriptor
        CALL    GBINIT

        ; Set CURBDP
        LXI     H,BDESC0
        SHLD    CURBDP

        ; Set block marks to FFFFH (unset)
        LXI     H,BDESC0+BD_MRKBG
        MVI     M,0FFH
        INX     H
        MVI     M,0FFH
        LXI     H,BDESC0+BD_MRKEN
        MVI     M,0FFH
        INX     H
        MVI     M,0FFH

        ; Fill BD_FNAME with spaces (12 bytes)
        LXI     H,BDESC0+BD_FNAME
        MVI     B,12
BFINLP: MVI     M,' '
        INX     H
        DCR     B
        JNZ     BFINLP

        ; Initialize key bindings table
        CALL    KBINIT

        ; Auto-detect terminal rows before drawing chrome so
        ; RSTAT/RSEPR/REROWS/RBYTPG reflect the real screen.
        CALL    DETSIZ

        ; Initialize and clear screen, draw chrome
        CALL    SCRINIT

        ; Load file from command line arg if present
        LDA     DFTFCB+1        ; first char of filename
        CPI     ' '             ; space means no arg
        JZ      STNOFL          ; no file, skip load
        LXI     D,DFTFCB        ; DE = FCB address
        CALL    FIOPEN          ; load into buffer
STNOFL:
        MVI     A,1
        STA     DIRTY           ; force full screen redraw

;------------------------------------------------------------
; MAINLP - Main edit loop
;------------------------------------------------------------
MAINLP:
        ; Check redraw level: DIRTY=full, DRTLINE=current row only
        LDA     DIRTY
        ORA     A
        JNZ     MLFULL          ; full redraw takes priority
        LDA     DRTLINE
        ORA     A
        JZ      MLDONE          ; no redraw needed
        ; Row-only redraw
        XRA     A
        STA     DRTLINE
        CALL    SCREDCL         ; redraw current hex row
        JMP     MLDONE
MLFULL:
        XRA     A
        STA     DIRTY           ; clear both flags
        STA     DRTLINE
        CALL    SCRDRAW         ; full screen redraw
MLDONE:
        ; If block mark is in progress (MRKBG set, MRKEN=FFFF),
        ; force full redraw so live highlight follows cursor
        MVI     A,BD_MRKBG
        CALL    BDFLD
        MOV     A,M
        INX     H
        ANA     M               ; A = low AND high of MRKBG
        INR     A
        JZ      MLNOML          ; MRKBG=FFFF: no mark active
        ; MRKBG set: check MRKEN
        MVI     A,BD_MRKEN
        CALL    BDFLD
        MOV     A,M
        INX     H
        ANA     M               ; A = low AND high of MRKEN
        INR     A
        JNZ     MLNOML          ; MRKEN set: mark complete, no live
        ; Live mark: force full redraw
        MVI     A,1
        STA     DIRTY
MLNOML:
        CALL    INFOBAR         ; always update info bar
        CALL    CURPOS          ; place HW cursor

        ; Get next key (blocking)
        CALL    GETKEY          ; B=type, C=code/char
        MOV     A,B
        ORA     A
        JZ      MAINLP          ; KT_NONE, try again

        CPI     KT_CHAR         ; printable character?
        JZ      DOCHAR

        ; Action code in C - range check then dispatch
        MOV     A,C
        ORA     A
        JZ      MAINLP          ; ACT_NONE
        CPI     ACT_MAX+1
        JNC     MAINLP          ; out of range, ignore

        ; Index into jump table: each entry = 2 bytes
        MOV     L,A
        MVI     H,0
        DAD     H               ; HL = index * 2
        LXI     D,ACTTBL
        DAD     D               ; HL = &ACTTBL[i*2]
        MOV     E,M
        INX     H
        MOV     D,M             ; DE = handler address
        XCHG
        PCHL                    ; jump to handler

;------------------------------------------------------------
; DOCHAR - Character input handler (hex or ASCII mode)
;------------------------------------------------------------
DOCHAR:
        ; C = character from GETKEY
        LDA     EDITMODE
        CPI     MODE_ASC
        JZ      DCASC           ; ASCII mode

        ;--- HEX MODE: accept 0-9, A-F, a-f only ---
        MOV     A,C
        CPI     '0'
        JC      DCBELL          ; < '0': reject
        CPI     '9'+1
        JC      DCHDIG          ; '0'-'9': digit
        CPI     'A'
        JC      DCBELL          ; ':'-'@': reject
        CPI     'F'+1
        JC      DCHUPR          ; 'A'-'F': uppercase hex
        CPI     'a'
        JC      DCBELL          ; 'G'-'`': reject
        CPI     'f'+1
        JC      DCLWR           ; 'a'-'f': lowercase hex
        JMP     DCBELL          ; > 'f': reject

DCHDIG: ; '0'-'9' -> nibble value 0-9
        MOV     A,C
        SUI     '0'
        JMP     DCNIB

DCHUPR: ; 'A'-'F' -> nibble value 10-15
        MOV     A,C
        SUI     'A'-10
        JMP     DCNIB

DCLWR:  ; 'a'-'f' -> nibble value 10-15
        MOV     A,C
        SUI     'a'-10

DCNIB:  ; A = nibble value (0-15)
        MOV     D,A             ; D = nibble value
        LDA     NIBBLE
        ORA     A
        JNZ     DCNLO           ; NIBBLE=1: low nibble

        ; High nibble: save and wait for low nibble
        MOV     A,D
        STA     HXNIB           ; save high nibble value
        MVI     A,1
        STA     NIBBLE          ; set state to low nibble
        ; Update display to show partial nibble entry
        CALL    INFOBAR
        CALL    CURPOS
        JMP     MAINLP

DCNLO:  ; Low nibble: combine with saved high nibble
        LDA     HXNIB           ; A = high nibble (0-15)
        RLC                     ; shift left 4 bits
        RLC
        RLC
        RLC
        ANI     0F0H            ; mask high nibble
        ORA     D               ; combine with low nibble
        MOV     C,A             ; C = full byte value

        ; Reset nibble state
        XRA     A
        STA     NIBBLE

        ; Insert or overwrite the byte
        LDA     INSMODE
        CPI     MODE_OVR
        JNZ     DCHINS          ; insert mode: just insert
        ; Overwrite: delete byte at cursor first (if not at end)
        PUSH    B               ; save byte value
        CALL    GBTXEND         ; HL = text length
        XCHG                    ; DE = text length
        CALL    GBCSOFF         ; HL = cursor offset
        MOV     A,L
        SUB     E
        MOV     A,H
        SBB     D
        POP     B               ; restore byte value
        JNC     DCHINS          ; at/past end: just insert
        PUSH    B
        CALL    GBDELRT         ; delete byte at cursor
        POP     B
        MOV     A,C             ; A = byte value
        CALL    GBINSRT         ; insert byte
        JMP     MLDRTL          ; overwrite: redraw current row
DCHINS: MOV     A,C             ; A = byte value
        CALL    GBINSRT         ; insert byte
        JMP     MLDIRT          ; insert: full redraw (shifts all rows)

DCASC:  ;--- ASCII MODE: accept 20H-7EH ---
        MOV     A,C
        CPI     20H
        JC      DCBELL          ; < space: reject
        CPI     7FH
        JNC     DCBELL          ; >= DEL: reject

        ; Insert or overwrite the byte
        PUSH    B               ; save char
        LDA     INSMODE
        CPI     MODE_OVR
        JNZ     DCAINS          ; insert mode: just insert
        ; Overwrite: delete byte at cursor first (if not at end)
        CALL    GBTXEND         ; HL = text length
        XCHG                    ; DE = text length
        CALL    GBCSOFF         ; HL = cursor offset
        MOV     A,L
        SUB     E
        MOV     A,H
        SBB     D
        JNC     DCAINS          ; at/past end: just insert
        CALL    GBDELRT         ; delete byte at cursor
        POP     B               ; restore char in C
        MOV     A,C
        CALL    GBINSRT         ; insert byte
        JMP     MLDRTL          ; overwrite: redraw current row
DCAINS: POP     B               ; restore char in C
        MOV     A,C
        CALL    GBINSRT         ; insert byte
        JMP     MLDIRT          ; insert: full redraw

DCBELL: ; Invalid character: sound bell
        MVI     E,BEL
        MVI     C,BF_RAWIO
        CALL    BDOS
        JMP     MAINLP

;------------------------------------------------------------
; Action handlers - each dispatched from ACTTBL
;------------------------------------------------------------

;--- Navigation: cursor up (16 bytes) ---
DO_CUU:
        XRA     A
        STA     NIBBLE          ; reset nibble state
        CALL    GBCSOFF         ; HL = cursor offset
        MOV     A,H
        ORA     A
        JNZ     CUUOK           ; high byte > 0, offset >= 256
        MOV     A,L
        CPI     16
        JC      MAINLP          ; offset < 16, can't go up
CUUOK:  ; Target = CSOFF - 16
        CALL    GBCSOFF         ; HL = cursor offset
        MVI     A,16
        MOV     E,A
        MVI     D,0             ; DE = 16
        MOV     A,L
        SUB     E
        MOV     E,A
        MOV     A,H
        SBB     D
        MOV     D,A             ; DE = CSOFF - 16
        XCHG                    ; HL = target
        CALL    GBMVTO          ; move cursor to HL
        CALL    CHKSCRL         ; auto-scroll if needed
        JMP     MAINLP

;--- Navigation: cursor down (16 bytes) ---
DO_CUD:
        XRA     A
        STA     NIBBLE          ; reset nibble state
        CALL    GBCSOFF         ; HL = cursor offset
        XCHG                    ; DE = cursor offset
        CALL    GBTXEND         ; HL = text length
        ; Check if CSOFF + 16 <= TXEND
        MOV     A,E
        ADI     16
        MOV     C,A
        MOV     A,D
        ACI     0
        MOV     B,A             ; BC = CSOFF + 16
        ; Compare BC <= HL (TXEND)
        MOV     A,B
        CMP     H
        JC      CDOK            ; BC < HL high byte
        JNZ     MAINLP          ; BC > HL high byte
        MOV     A,C
        CMP     L
        JZ      CDOK            ; BC == HL
        JNC     MAINLP          ; BC > HL
CDOK:   ; Target = CSOFF + 16
        MOV     D,B
        MOV     E,C             ; DE = CSOFF + 16
        XCHG                    ; HL = target
        CALL    GBMVTO          ; move cursor to HL
        CALL    CHKSCRL         ; auto-scroll if needed
        JMP     MAINLP

;--- Navigation: cursor left (1 byte) ---
DO_CUL:
        XRA     A
        STA     NIBBLE          ; reset nibble state
        CALL    GBMVLT          ; move left one byte
        CALL    CHKSCRL         ; auto-scroll if needed
        JMP     MAINLP

;--- Navigation: cursor right (1 byte) ---
DO_CUR:
        XRA     A
        STA     NIBBLE          ; reset nibble state
        CALL    GBMVRT          ; move right one byte
        CALL    CHKSCRL         ; auto-scroll if needed
        JMP     MAINLP

;--- Navigation: page up (BYTESPG bytes) ---
DO_PGU:
        XRA     A
        STA     NIBBLE          ; reset nibble state
        LHLD    RBYTPG          ; HL = runtime bytes/page
        XCHG                    ; DE = runtime bytes/page
        CALL    GBCSOFF         ; HL = cursor offset
        ; Target = max(0, CSOFF - BYTESPG)
        MOV     A,L
        SUB     E
        MOV     E,A
        MOV     A,H
        SBB     D
        MOV     D,A             ; DE = CSOFF - BYTESPG
        JNC     PGUSET          ; no underflow
        LXI     D,0             ; clamp to 0
PGUSET: XCHG                    ; HL = target
        CALL    GBMVTO
        CALL    CHKSCRL         ; adjust TOPOFF if needed
        JMP     MLDIRT

;--- Navigation: page down (BYTESPG bytes) ---
DO_PGD:
        XRA     A
        STA     NIBBLE          ; reset nibble state
        CALL    GBCSOFF         ; HL = cursor offset
        XCHG                    ; DE = cursor offset
        CALL    GBTXEND         ; HL = text length
        PUSH    H               ; save TXEND
        ; Target = min(CSOFF + BYTESPG, TXEND)
        LHLD    RBYTPG          ; HL = runtime bytes/page
        DAD     D               ; HL = CSOFF + BYTESPG
        JC      PGDCLM          ; overflow: clamp to TXEND
        POP     D               ; DE = TXEND
        PUSH    D
        ; Compare HL vs DE (TXEND)
        MOV     A,H
        CMP     D
        JC      PGDOK           ; HL < TXEND
        JNZ     PGDCLM          ; HL > TXEND
        MOV     A,L
        CMP     E
        JC      PGDOK           ; HL < TXEND
        JZ      PGDOK           ; HL == TXEND
PGDCLM: POP     H               ; HL = TXEND (clamped target)
        JMP     PGDGO
PGDOK:  XCHG                    ; DE = target, save it
        POP     H               ; discard saved TXEND
        XCHG                    ; HL = target
PGDGO:  CALL    GBMVTO
        CALL    CHKSCRL         ; adjust TOPOFF if needed
        JMP     MLDIRT

;--- Navigation: home (start of current 16-byte row) ---
DO_HOM:
        XRA     A
        STA     NIBBLE          ; reset nibble state
        CALL    GBCSOFF         ; HL = cursor offset
        ; Target = CSOFF AND FFF0H (align to 16)
        MOV     A,L
        ANI     0F0H
        MOV     L,A             ; HL = CSOFF & FFF0H
        CALL    GBMVTO
        JMP     MAINLP

;--- Navigation: end (end of current 16-byte row) ---
DO_END:
        XRA     A
        STA     NIBBLE          ; reset nibble state
        CALL    GBCSOFF         ; HL = cursor offset
        ; Target = min(CSOFF | 000FH, TXEND)
        MOV     A,L
        ORI     0FH
        MOV     E,A
        MOV     D,H             ; DE = CSOFF | 000FH
        PUSH    D               ; save row end
        CALL    GBTXEND         ; HL = text length
        POP     D               ; DE = row end offset
        ; Compare DE vs HL (TXEND)
        MOV     A,D
        CMP     H
        JC      ENDOK           ; DE < TXEND
        JNZ     ENDCLM          ; DE > TXEND
        MOV     A,E
        CMP     L
        JC      ENDOK           ; DE < TXEND
        JZ      ENDOK           ; DE == TXEND
ENDCLM: ; Clamp to TXEND (HL already = TXEND)
        JMP     ENDGO
ENDOK:  XCHG                    ; HL = target (was in DE)
ENDGO:  CALL    GBMVTO
        JMP     MAINLP

;--- Navigation: top of file ---
DO_FTP:
        XRA     A
        STA     NIBBLE          ; reset nibble state
        CALL    GBMVTP         ; cursor to offset 0
        ; Set TOPOFF = 0
        MVI     A,BD_TOPOFF
        CALL    BDFLD           ; HL -> BD_TOPOFF
        MVI     M,0
        INX     H
        MVI     M,0
        JMP     MLDIRT

;--- Navigation: end of file ---
DO_FEN:
        XRA     A
        STA     NIBBLE          ; reset nibble state
        CALL    GBMVEND         ; cursor to last byte
        ; Adjust TOPOFF so cursor is visible
        CALL    ADJTOFE         ; adjust TOPOFF for file end
        JMP     MLDIRT

;--- Editing: delete left (backspace) ---
DO_DLF:
        XRA     A
        STA     NIBBLE          ; reset nibble state
        CALL    GBDLFT          ; delete byte left of cursor
        ORA     A
        JNZ     MAINLP          ; A=FFH: at start, nothing deleted
        CALL    CHKSCRL
        JMP     MLDIRT

;--- Editing: delete right ---
DO_DRT:
        XRA     A
        STA     NIBBLE          ; reset nibble state
        CALL    GBDELRT         ; delete byte at cursor
        ORA     A
        JNZ     MAINLP          ; A=FFH: at end, nothing deleted
        JMP     MLDIRT

;--- Editing: toggle insert/overwrite ---
DO_TIN:
        LDA     INSMODE
        XRI     1               ; toggle 0<->1
        STA     INSMODE
        CALL    INFOBAR         ; update mode display
        JMP     MAINLP

;--- Editing: toggle hex/ascii mode ---
DO_TMD:
        XRA     A
        STA     NIBBLE          ; reset nibble state
        LDA     EDITMODE
        XRI     1               ; toggle MODE_HEX<->MODE_ASC
        STA     EDITMODE
        CALL    INFOBAR         ; update mode display
        CALL    CURPOS          ; reposition cursor for new field
        JMP     MAINLP

;--- Editing: delete row (16 bytes) ---
DO_DRW:
        XRA     A
        STA     NIBBLE          ; reset nibble state
        ; Delete up to 16 bytes at cursor position
        MVI     B,16            ; B = count
DRWLP:  PUSH    B
        CALL    GBTXEND         ; HL = text length
        XCHG                    ; DE = text length
        CALL    GBCSOFF         ; HL = cursor offset
        ; If CSOFF >= TXEND, stop
        MOV     A,L
        SUB     E
        MOV     A,H
        SBB     D
        POP     B
        JNC     DRWDN           ; at or past end
        PUSH    B
        CALL    GBDELRT         ; delete one byte
        POP     B
        DCR     B
        JNZ     DRWLP
DRWDN:  JMP     MLDIRT

;--- Find next ---
DO_FNX:
        XRA     A
        STA     NIBBLE          ; reset nibble state
        CALL    SRFNDNX
        JMP     MLDIRT

;--- Save file ---
DO_SAV:
        ; Check if filename exists (BD_FNAME[1] != space)
        MVI     A,BD_FNAME+1
        CALL    BDFLD
        MOV     A,M
        ANI     7FH
        CPI     ' '
        JNZ     DSAVGO          ; has name, save directly
        ; No name - prompt for one
        LXI     D,EXTASPMT      ; "Save as: "
        CALL    FIPROMPT
        JZ      DSAVDN          ; user cancelled
        CALL    FISAVFN         ; copy WRKFCB name to BD_FNAME
DSAVGO: LXI     D,SAVWMSG
        CALL    STATMSG
        CALL    FISAVE
DSAVDN: CALL    INFOBAR
        JMP     MAINLP

;--- Exit editor ---
DO_EXT: CALL    DOEXIT          ; save & exit
        JMP     MAINLP          ; returns if cancelled

;--- Block operations ---
DO_BMK: CALL    BLMARK
        JMP     MLDIRT
DO_BCP: CALL    BLCOPY
        CALL    CHKSCRL
        JMP     MLDIRT
DO_BDL: CALL    BLDEL
        CALL    CHKSCRL
        JMP     MLDIRT
DO_BPS: CALL    BLPASTE
        CALL    CHKSCRL
        JMP     MLDIRT

;--- Menu ---
DO_MNU: CALL    MNUSHOW
        JMP     MLDIRT

;------------------------------------------------------------
; Shared exit points for action handlers
;------------------------------------------------------------
MLDIRT: MVI     A,1
        STA     DIRTY
        JMP     MAINLP
MLDRTL: MVI     A,1
        STA     DRTLINE
        JMP     MAINLP

;------------------------------------------------------------
; CHKSCRL - Check if cursor is outside visible range.
; If CSOFF < TOPOFF or CSOFF >= TOPOFF+BYTESPG, adjust
; TOPOFF and set DIRTY=1 for full redraw.
; Entry:  (none)
; Exit:   AF DE HL clobbered; DIRTY set if scrolled
;------------------------------------------------------------
CHKSCRL:
        CALL    GBCSOFF         ; HL = cursor offset
        XCHG                    ; DE = CSOFF
        MVI     A,BD_TOPOFF
        CALL    BDFLD           ; HL -> BD_TOPOFF
        MOV     C,M
        INX     H
        MOV     B,M             ; BC = TOPOFF

        ; Check if CSOFF < TOPOFF
        MOV     A,E
        SUB     C
        MOV     A,D
        SBB     B
        JC      CSABOV          ; CSOFF < TOPOFF: cursor above

        ; Check if CSOFF >= TOPOFF + BYTESPG
        PUSH    D               ; save CSOFF
        LHLD    RBYTPG          ; HL = runtime bytes/page
        DAD     B               ; HL = TOPOFF + BYTESPG
        XCHG                    ; DE = TOPOFF + BYTESPG
        POP     H               ; HL = CSOFF
        ; Compare HL (CSOFF) vs DE (TOPOFF + BYTESPG)
        MOV     A,H
        CMP     D
        JC      CSOK            ; CSOFF < limit, visible
        JNZ     CSBELOW         ; CSOFF > limit high byte
        MOV     A,L
        CMP     E
        JC      CSOK            ; CSOFF < limit, visible
        ; CSOFF >= limit: cursor below viewport

CSBELOW:
        ; Set TOPOFF = (CSOFF AND FFF0H) - BYTESPG + 16
        CALL    GBCSOFF         ; HL = CSOFF
        MOV     A,L
        ANI     0F0H
        MOV     L,A             ; HL = CSOFF aligned to 16
        CALL    BPG16           ; DE = RBYTPG - 16, HL preserved
        MOV     A,L
        SUB     E
        MOV     E,A
        MOV     A,H
        SBB     D
        MOV     D,A             ; DE = new TOPOFF
        JNC     CSSET           ; no underflow
        LXI     D,0             ; clamp to 0
        JMP     CSSET

CSABOV:
        ; Set TOPOFF = CSOFF AND FFF0H (align to 16)
        CALL    GBCSOFF         ; HL = CSOFF
        MOV     A,L
        ANI     0F0H
        MOV     E,A
        MOV     D,H             ; DE = aligned CSOFF

CSSET:  ; Store new TOPOFF in DE
        MVI     A,BD_TOPOFF
        CALL    BDFLD           ; HL -> BD_TOPOFF
        MOV     M,E
        INX     H
        MOV     M,D
        MVI     A,1
        STA     DIRTY
CSOK:   RET

;------------------------------------------------------------
; ADJTOFE - Adjust TOPOFF when jumping to file end.
; Sets TOPOFF so cursor is on the last visible page.
; Entry:  Cursor already at end of file
; Exit:   AF DE HL clobbered
;------------------------------------------------------------
ADJTOFE:
        CALL    GBTXEND         ; HL = text length
        ; New TOPOFF = max(0, (TXEND & FFF0H) - BYTESPG + 16)
        MOV     A,L
        ANI     0F0H
        MOV     L,A             ; HL = TXEND aligned to 16
        CALL    BPG16           ; DE = RBYTPG - 16, HL preserved
        MOV     A,L
        SUB     E
        MOV     E,A
        MOV     A,H
        SBB     D
        MOV     D,A             ; DE = new TOPOFF
        JNC     ATFSET          ; no underflow
        LXI     D,0             ; clamp to 0
ATFSET: MVI     A,BD_TOPOFF
        CALL    BDFLD           ; HL -> BD_TOPOFF
        MOV     M,E
        INX     H
        MOV     M,D
        RET

;------------------------------------------------------------
; DOEXIT - Prompt to save, handle unnamed files, exit.
; If buffer is unmodified: exits immediately.
; If modified: asks "Save? (Y/N/Esc)".
;   Y = save (prompts for name if unnamed), then exit.
;   N = discard changes, exit.
;   Esc = cancel, returns to editor.
; Exit:   Warm boots CP/M (does not return) unless cancelled.
;------------------------------------------------------------
DOEXIT:
        ; Check if buffer modified
        CALL    FISMOD
        ORA     A
        JZ      DXEXIT          ; not modified, just exit

        ; Buffer is modified - ask user
        LXI     D,EXTSAVQ       ; "Save changes? (Y/N/Esc) "
        CALL    STATMSG
        MVI     C,BF_CONIN
        CALL    BDOS

        ; Check response
        CPI     'Y'
        JZ      DXYES
        CPI     'y'
        JZ      DXYES
        CPI     'N'
        JZ      DXEXIT          ; discard changes, exit
        CPI     'n'
        JZ      DXEXIT
        ; Any other key = cancel (return to editor)
        JMP     DXRET

DXYES:
        ; Check if filename exists (BD_FNAME[1] != space)
        MVI     A,BD_FNAME+1
        CALL    BDFLD
        MOV     A,M
        ANI     7FH
        CPI     ' '
        JNZ     DXSAVE          ; has name, save directly

        ; No name - clear status bar and prompt for filename
        LXI     D,CLRMSG
        CALL    STATMSG         ; clear status bar
        LDA     RSTAT           ; B = runtime status row
        MOV     B,A
        MVI     C,1
        CALL    CURGOTO
        LXI     D,EXTASPMT      ; "Save as: "
        CALL    FIPROMPT
        JZ      DXRET           ; user cancelled filename entry
        CALL    FISAVFN         ; copy WRKFCB name to BD_FNAME

DXSAVE:
        LXI     D,SAVWMSG
        CALL    STATMSG
        CALL    FISAVE

DXEXIT:
        LXI     D,CLRMSG
        CALL    STATMSG
        JMP     WBOOT           ; return to CP/M

DXRET:  LXI     D,CLRMSG
        JMP     STATMSG         ; clear leftover prompt

;------------------------------------------------------------
; MEMFAIL - Not enough memory to run.
;------------------------------------------------------------
MEMFAIL:
        LXI     D,NOMEMSG
        MVI     C,BF_PRTSTR
        CALL    BDOS
        JMP     WBOOT

;------------------------------------------------------------
; BDFLD - Compute pointer to buffer descriptor field.
; Entry:  A = field offset (BD_xxx constant)
; Exit:   HL -> field in current descriptor; A clobbered
;------------------------------------------------------------
BDFLD:
        LHLD    CURBDP
        ADD     L
        MOV     L,A
        MVI     A,0
        ADC     H
        MOV     H,A
        RET

;------------------------------------------------------------
; Action dispatch table - word (address) per action code.
; Index 0 = ACT_NONE (unused), 1..ACT_MAX = handlers.
;------------------------------------------------------------
ACTTBL:
        DW      MAINLP          ;  0 ACT_NONE
        DW      DO_CUU          ;  1 ACT_CURUP
        DW      DO_CUD          ;  2 ACT_CURDN
        DW      DO_CUL          ;  3 ACT_CURLT
        DW      DO_CUR          ;  4 ACT_CURRT
        DW      DO_PGU          ;  5 ACT_PGUP
        DW      DO_PGD          ;  6 ACT_PGDN
        DW      DO_HOM          ;  7 ACT_HOME
        DW      DO_END          ;  8 ACT_END
        DW      DO_FTP          ;  9 ACT_FTOP
        DW      DO_FEN          ; 10 ACT_FEND
        DW      DO_DLF          ; 11 ACT_DELLF
        DW      DO_DRT          ; 12 ACT_DELRT
        DW      DO_TIN          ; 13 ACT_TOGIN
        DW      DO_TMD          ; 14 ACT_TOGMD
        DW      DO_FNX          ; 15 ACT_FNDNX
        DW      DO_SAV          ; 16 ACT_FSAVE
        DW      DO_EXT          ; 17 ACT_FEXIT
        DW      DO_BMK          ; 18 ACT_BLKMK
        DW      DO_BCP          ; 19 ACT_BLKCP
        DW      DO_BDL          ; 20 ACT_BLKDL
        DW      DO_BPS          ; 21 ACT_BLKPS
        DW      DO_MNU          ; 22 ACT_MENU
        DW      DO_DRW          ; 23 ACT_DELRW
        DW      MAINLP          ; 24 ACT_ENTER (no-op in editor)

;=============================================================
; BPG16 - Load DE with (RBYTPG - 16). HL preserved.
; Used by scroll/page-alignment code that needs the runtime
; bytes-per-page minus one display row.
; Entry:  (none)
; Exit:   DE = RBYTPG - 16, HL unchanged, A/F clobbered.
;=============================================================
BPG16:  PUSH    H
        LHLD    RBYTPG          ; HL = runtime bytes/page
        LXI     D,-16           ; DE = 0FFF0H (two's complement -16)
        DAD     D               ; HL = RBYTPG - 16
        XCHG                    ; DE = RBYTPG - 16
        POP     H               ; restore caller's HL
        RET

;--- String constants ---------------------------------
NOMEMSG: DB     'Insufficient memory',CR,LF,'$'
CLRMSG:  DB     ' $'
SAVWMSG: DB     'Saving file, please wait...$'
EXTSAVQ: DB     'Save changes? (Y/N/Esc) $'
EXTASPMT: DB    'Save as: $'

;=============================================================
; DATA SEGMENT
;=============================================================
        DSEG

OLDSP:   DW     0               ; saved entry SP
TPATOP:  DW     0               ; BDOS address / TPA top

;--- Runtime screen dimensions (defaults = 24-row VT100,
;    DETSIZ may rewrite at startup) ---------------------
REROWS:  DB     EDITROW         ; edit-area row count (20)
RSEPR:   DB     SEPRROW         ; separator row       (23)
RSTAT:   DB     STATROW         ; status / prompt row (24)
RBYTPG:  DW     BYTESPG         ; bytes per page      (320)

INSMODE: DB     MODE_OVR        ; insert/overwrite (default OVR)
DIRTY:   DB     1               ; 1 = full screen redraw needed
DRTLINE: DB     0               ; 1 = redraw current row only
EDITMODE: DB    MODE_HEX        ; 0=hex mode, 1=ascii mode
NIBBLE:  DB     0               ; 0=high nibble, 1=low nibble
HXNIB:   DB     0               ; saved high nibble value
CURBDP:  DW     0               ; ptr to active buf desc
BDESC0:  DS     BD_SIZE         ; buffer descriptor (32 bytes)

;--- Stack (64 words) ---------------------------------
        DS      128
STKTOP  EQU     $               ; SP points here

        END     START
